<div class="page-header">
    <div style="display: flex; justify-content: space-between; align-items: center;">
        <div>
            <h1 class="page-title">Trading Journal</h1>
            <p class="page-subtitle">Track every move and master your setups.</p>
        </div>
        <a href="/trades/add" class="btn btn-primary">
            <i data-lucide="plus" style="width: 16px;"></i>
            New Entry
        </a>
    </div>
</div>

<!-- Search & Filter Bar (Minimalist) -->
<div class="card-table-wrapper" style="margin-bottom: 1.5rem; padding: 1rem 1.5rem;">
    <form action="/trades" method="GET" style="display: flex; gap: 1rem; flex-wrap: wrap;">
        <div style="flex: 1; min-width: 200px; position: relative;">
            <i data-lucide="search" style="position: absolute; left: 12px; top: 50%; transform: translateY(-50%); width: 16px; color: var(--text-muted);"></i>
            <input type="text" name="pair" placeholder="Search pair (e.g. BTCUSD)" 
                   style="width: 100%; padding: 0.6rem 0.6rem 0.6rem 2.5rem; border-radius: var(--radius); border: 1px solid var(--border); font-family: inherit; font-size: 0.9rem;"
                   value="<%= filters.pair || '' %>">
        </div>
        <select name="result" style="padding: 0.6rem; border-radius: var(--radius); border: 1px solid var(--border); background: var(--white); font-family: inherit; font-size: 0.9rem; min-width: 120px;">
            <option value="">All Results</option>
            <option value="win" <%= filters.result === 'win' ? 'selected' : '' %>>Win</option>
            <option value="loss" <%= filters.result === 'loss' ? 'selected' : '' %>>Loss</option>
            <option value="BE" <%= filters.result === 'BE' ? 'selected' : '' %>>Break Even</option>
        </select>
        <button type="submit" class="btn btn-ghost">Apply Filters</button>
    </form>
</div>

<div class="card-table-wrapper">
    <table>
        <thead>
            <tr>
                <th>Date / Time</th>
                <th>Instrument</th>
                <th>Setup</th>
                <th style="text-align: center;">Result</th>
                <th style="text-align: right;">PnL</th>
                <th style="text-align: right;">Actions</th>
            </tr>
        </thead>
        <tbody>
            <% trades.forEach(trade => { %>
            <tr>
                <td>
                    <div style="font-weight: 500;"><%= moment(trade.date).format('MMM DD, YYYY') %></div>
                    <div style="font-size: 0.7rem; color: var(--text-muted);"><%= trade.session %> Session</div>
                </td>
                <td>
                    <div style="font-weight: 700; color: var(--primary);"><%= trade.pair %></div>
                    <div style="font-size: 0.7rem; color: var(--text-muted);"><%= trade.propfirm_name %></div>
                </td>
                <td>
                    <span style="font-size: 0.85rem; font-weight: 500;"><%= trade.setup %></span>
                    <div style="font-size: 0.7rem; color: var(--text-muted);">RR: <%= trade.reward_risk || '1:1' %></div>
                </td>
                <td style="text-align: center;">
                    <span class="badge badge-<%= trade.result === 'win' ? 'success' : (trade.result === 'loss' ? 'danger' : 'warning') %>">
                        <%= trade.result.toUpperCase() %>
                    </span>
                </td>
                <td style="text-align: right; font-weight: 700; font-size: 1rem;" class="<%= trade.pnl >= 0 ? 'positive' : 'negative' %>">
                    <%= trade.pnl >= 0 ? '+' : '' %>$<%= Math.abs(trade.pnl).toLocaleString() %>
                </td>
                <td style="text-align: right;">
                    <div style="display: flex; justify-content: flex-end; gap: 0.5rem;">
                        <a href="/trades/<%= trade.id %>/edit" class="btn btn-ghost" style="padding: 0.4rem;"><i data-lucide="edit-3" style="width: 16px;"></i></a>
                        <form action="/trades/<%= trade.id %>?_method=DELETE" method="POST" onsubmit="return confirm('Delete this trade entry?')">
                            <button type="submit" class="btn btn-ghost" style="padding: 0.4rem; color: var(--danger);"><i data-lucide="trash-2" style="width: 16px;"></i></button>
                        </form>
                    </div>
                </td>
            </tr>
            <% }) %>
        </tbody>
    </table>
    <% if (trades.length === 0) { %>
        <div style="padding: 3rem; text-align: center; color: var(--text-muted);">
            No trades found. Time to search for an entry! 🏹
        </div>
    <% } %>
</div>
