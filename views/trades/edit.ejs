<div class="max-w-4xl mx-auto">
    <div class="bg-white dark:bg-slate-800 rounded-3xl shadow-xl border border-slate-100 dark:border-slate-700 overflow-hidden">
        <div class="px-8 py-6 border-b border-slate-100 dark:border-slate-700 bg-slate-50/50 dark:bg-slate-800/50">
            <h2 class="text-xl font-bold text-slate-800 dark:text-slate-100">Edit Trade Entry</h2>
            <p class="text-xs text-slate-400 mt-1 font-medium italic">Update your execution details or add post-trade reflections.</p>
        </div>

        <form action="/trades/<%= trade.id %>?_method=PUT" method="POST" enctype="multipart/form-data" class="p-8">
            <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
                
                <!-- Basic Info Segment -->
                <div>
                    <label class="block text-xs font-bold text-slate-400 uppercase tracking-widest mb-2">Trade Date</label>
                    <input type="date" name="date" required value="<%= moment(trade.date).format('YYYY-MM-DD') %>"
                           class="w-full px-4 py-3 rounded-xl border border-slate-200 dark:border-slate-700 bg-slate-50 dark:bg-slate-900 text-slate-800 dark:text-slate-100 focus:outline-none focus:ring-2 focus:ring-blue-500/20 focus:border-blue-500 transition-all cursor-pointer font-medium">
                </div>
                <div>
                    <label class="block text-xs font-bold text-slate-400 uppercase tracking-widest mb-2">Symbol / Pair</label>
                    <input type="text" name="pair" required value="<%= trade.pair %>"
                           class="w-full px-4 py-3 rounded-xl border border-slate-200 dark:border-slate-700 bg-slate-50 dark:bg-slate-900 text-slate-800 dark:text-slate-100 focus:outline-none focus:ring-2 focus:ring-blue-500/20 focus:border-blue-500 transition-all font-bold tracking-tight">
                </div>
                <div>
                    <label class="block text-xs font-bold text-slate-400 uppercase tracking-widest mb-2">Trading Session</label>
                    <select name="session" class="w-full px-4 py-3 rounded-xl border border-slate-200 dark:border-slate-700 bg-slate-50 dark:bg-slate-900 text-slate-800 dark:text-slate-100 focus:outline-none focus:ring-2 focus:ring-blue-500/20 focus:border-blue-500 transition-all appearance-none cursor-pointer font-medium">
                        <option value="London" <%= trade.session === 'London' ? 'selected' : '' %>>London</option>
                        <option value="New York" <%= trade.session === 'New York' ? 'selected' : '' %>>New York</option>
                        <option value="Asia" <%= trade.session === 'Asia' ? 'selected' : '' %>>Asia</option>
                    </select>
                </div>

                <!-- Account Selection -->
                <div class="md:col-span-2">
                    <label class="block text-xs font-bold text-slate-400 uppercase tracking-widest mb-2">Linked Trading Account</label>
                    <select name="account_id" class="w-full px-4 py-3 rounded-xl border border-slate-200 dark:border-slate-700 bg-slate-50 dark:bg-slate-900 text-slate-800 dark:text-slate-100 focus:outline-none focus:ring-2 focus:ring-blue-500/20 focus:border-blue-500 transition-all appearance-none cursor-pointer font-medium">
                        <option value="">Standalone / Personal Journal</option>
                        <% accounts.forEach(acc => { %>
                        <option value="<%= acc.id %>" <%= trade.account_id === acc.id ? 'selected' : '' %>>🏦 <%= acc.propfirm_name %> — <%= acc.account_name %></option>
                        <% }) %>
                    </select>
                </div>
                <div>
                    <label class="block text-xs font-bold text-slate-400 uppercase tracking-widest mb-2">Setup / Model</label>
                    <input type="text" name="setup" value="<%= trade.setup %>"
                           class="w-full px-4 py-3 rounded-xl border border-slate-200 dark:border-slate-700 bg-slate-50 dark:bg-slate-900 text-slate-800 dark:text-slate-100 focus:outline-none focus:ring-2 focus:ring-blue-500/20 focus:border-blue-500 transition-all">
                </div>

                <!-- Price Data Segment -->
                <div class="bg-slate-50 dark:bg-slate-900/50 p-6 rounded-2xl md:col-span-3 grid grid-cols-1 md:grid-cols-3 gap-6 border border-slate-100 dark:border-slate-800">
                    <div>
                        <label class="block text-[10px] font-bold text-slate-400 uppercase tracking-widest mb-2">Entry Price</label>
                        <input type="number" step="0.00001" name="entry_price" value="<%= trade.entry_price %>" placeholder="0.00000"
                               class="w-full px-4 py-2.5 rounded-xl border border-slate-200 dark:border-slate-700 bg-white dark:bg-slate-800 text-slate-800 dark:text-slate-100 focus:outline-none focus:ring-2 focus:ring-blue-500/20 transition-all">
                    </div>
                    <div>
                        <label class="block text-[10px] font-bold text-slate-400 uppercase tracking-widest mb-2">Stop Loss</label>
                        <input type="number" step="0.00001" name="stop_loss" value="<%= trade.stop_loss %>" placeholder="0.00000"
                               class="w-full px-4 py-2.5 rounded-xl border border-slate-200 dark:border-slate-700 bg-white dark:bg-slate-800 text-slate-800 dark:text-slate-100 focus:outline-none focus:ring-2 focus:ring-rose-500/20 transition-all focus:border-rose-400/50">
                    </div>
                    <div>
                        <label class="block text-[10px] font-bold text-slate-400 uppercase tracking-widest mb-2">Take Profit</label>
                        <input type="number" step="0.00001" name="take_profit" value="<%= trade.take_profit %>" placeholder="0.00000"
                               class="w-full px-4 py-2.5 rounded-xl border border-slate-200 dark:border-slate-700 bg-white dark:bg-slate-800 text-slate-800 dark:text-slate-100 focus:outline-none focus:ring-2 focus:ring-emerald-500/20 transition-all focus:border-emerald-400/50">
                    </div>
                </div>

                <!-- Result Data Segment -->
                <div>
                    <label class="block text-xs font-bold text-slate-400 uppercase tracking-widest mb-2">Risk Amount ($)</label>
                    <input type="number" step="0.01" name="risk" value="<%= trade.risk %>"
                           class="w-full px-4 py-3 rounded-xl border border-slate-200 dark:border-slate-700 bg-slate-50 dark:bg-slate-900 text-slate-800 dark:text-slate-100 focus:outline-none focus:ring-2 focus:ring-blue-500/20 transition-all">
                </div>
                <div>
                    <label class="block text-xs font-bold text-slate-400 uppercase tracking-widest mb-2">Trade Result</label>
                    <select name="result" class="w-full px-4 py-3 rounded-xl border border-slate-200 dark:border-slate-700 bg-slate-50 dark:bg-slate-900 text-slate-800 dark:text-slate-100 focus:outline-none focus:ring-2 focus:ring-blue-500/20 transition-all appearance-none cursor-pointer font-bold uppercase tracking-wider text-center">
                        <option value="BE" <%= trade.result === 'BE' ? 'selected' : '' %>>Break Even</option>
                        <option value="win" <%= trade.result === 'win' ? 'selected' : '' %>>Won Trade</option>
                        <option value="loss" <%= trade.result === 'loss' ? 'selected' : '' %>>Loss Trade</option>
                    </select>
                </div>
                <div>
                    <label class="block text-xs font-bold text-slate-400 uppercase tracking-widest mb-2">Profit / Loss ($)</label>
                    <input type="number" step="0.01" name="pnl" value="<%= trade.pnl %>"
                           class="w-full px-4 py-3 rounded-xl border border-slate-200 dark:border-slate-700 bg-slate-50 dark:bg-slate-900 text-slate-800 dark:text-slate-100 focus:outline-none focus:ring-2 focus:ring-blue-500/20 transition-all font-bold">
                </div>

                <div class="md:col-span-3">
                    <label class="block text-xs font-bold text-slate-400 uppercase tracking-widest mb-2">Post-Trade Notes & Psychology</label>
                    <textarea name="note" rows="4" placeholder="Describe your mindset, market conditions, and mistakes..."
                              class="w-full px-5 py-4 rounded-2xl border border-slate-200 dark:border-slate-700 bg-slate-50 dark:bg-slate-900 text-slate-800 dark:text-slate-100 focus:outline-none focus:ring-2 focus:ring-blue-500/20 transition-all text-sm leading-relaxed"><%= trade.note %></textarea>
                </div>

                <div class="md:col-span-3 grid grid-cols-1 md:grid-cols-2 gap-6 items-center">
                    <div>
                        <label class="block text-xs font-bold text-slate-400 uppercase tracking-widest mb-2 text-center md:text-left">Update Screenshot</label>
                        <div class="mt-1 flex justify-center px-6 pt-5 pb-6 border-2 border-slate-200 dark:border-slate-700 border-dashed rounded-2xl hover:border-blue-400 transition-colors">
                            <div class="space-y-1 text-center">
                                <svg class="mx-auto h-8 w-8 text-slate-300" stroke="currentColor" fill="none" viewBox="0 0 48 48">
                                    <path d="M28 8H12a4 4 0 00-4 4v20m32-12v8m0 0v8a4 4 0 01-4 4H12a4 4 0 01-4-4v-4m32-4l-3.172-3.172a4 4 0 00-5.656 0L28 28M8 32l9.172-9.172a4 4 0 015.656 0L28 28m0 0l4 4m4-24h8m-4-4v8m-12 4h.02" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" />
                                </svg>
                                <label for="file-upload" class="cursor-pointer font-bold text-blue-500 hover:text-blue-600 block text-xs mt-2">
                                    <span>Change Chart Image</span>
                                    <input id="file-upload" name="screenshot" type="file" accept="image/*" class="sr-only">
                                </label>
                                <p id="file-name" class="text-[9px] text-emerald-500 font-bold mt-1 uppercase"></p>
                            </div>
                        </div>
                    </div>
                    <% if (trade.screenshot) { %>
                    <div class="flex flex-col items-center">
                        <span class="text-[10px] font-bold text-slate-400 uppercase mb-2 italic">Current Screenshot</span>
                        <div class="relative group">
                            <img src="<%= trade.screenshot %>" 
                                 class="w-48 h-28 object-cover rounded-xl border-2 border-slate-200 dark:border-slate-700 shadow-sm cursor-zoom-in group-hover:opacity-75 transition-all"
                                 onclick="window.open('<%= trade.screenshot %>', '_blank')">
                            <div class="absolute inset-0 flex items-center justify-center opacity-0 group-hover:opacity-100 transition-opacity pointer-events-none">
                                <span class="bg-black/50 text-white text-[10px] px-2 py-1 rounded-full font-bold">VIEW FULL</span>
                            </div>
                        </div>
                    </div>
                    <% } %>
                </div>
            </div>

            <div class="mt-10 flex gap-4">
                <button type="submit" class="flex-1 bg-blue-600 hover:bg-blue-700 text-white font-bold py-4 px-8 rounded-2xl transition-all shadow-xl shadow-blue-500/25 flex items-center justify-center gap-2">
                    <span>💾 Update Trade Record</span>
                </button>
                <a href="/trades" class="px-10 py-4 rounded-2xl bg-slate-100 dark:bg-slate-700 hover:bg-slate-200 dark:hover:bg-slate-600 text-slate-600 dark:text-slate-300 font-bold transition-all flex items-center">
                    Cancel
                </a>
            </div>
        </form>
    </div>
</div>

<script>
    document.getElementById('file-upload').addEventListener('change', function(e) {
        const fileName = e.target.files[0] ? e.target.files[0].name : '';
        document.getElementById('file-name').textContent = fileName ? '📎 SELECTED: ' + fileName : '';
    });
</script>
