<div class="card" style="max-width: 800px; margin: 0 auto;">
    <h2 class="card-title">Edit Trade Entry</h2>
    <form action="/trades/<%= trade.id %>?_method=PUT" method="POST" enctype="multipart/form-data">
        <div class="grid-2">
            <div class="form-group">
                <label>Date</label>
                <input type="date" name="date" class="form-control" required value="<%= moment(trade.date).format('YYYY-MM-DD') %>">
            </div>
            <div class="form-group">
                <label>Pair</label>
                <input type="text" name="pair" class="form-control" required value="<%= trade.pair %>">
            </div>
        </div>

        <div class="grid-2">
            <div class="form-group">
                <label>Session</label>
                <select name="session" class="form-control">
                    <option value="London" <%= trade.session === 'London' ? 'selected' : '' %>>London</option>
                    <option value="New York" <%= trade.session === 'New York' ? 'selected' : '' %>>New York</option>
                    <option value="Asia" <%= trade.session === 'Asia' ? 'selected' : '' %>>Asia</option>
                </select>
            </div>
            <div class="form-group">
                <label>Account (Optional)</label>
                <select name="account_id" class="form-control">
                    <option value="">Standalone / Personal</option>
                    <% accounts.forEach(acc => { %>
                    <option value="<%= acc.id %>" <%= trade.account_id === acc.id ? 'selected' : '' %>><%= acc.account_name %></option>
                    <% }) %>
                </select>
            </div>
        </div>

        <div class="form-group">
            <label>Setup / Strategy</label>
            <input type="text" name="setup" class="form-control" value="<%= trade.setup %>">
        </div>

        <div class="grid-2" style="grid-template-columns: repeat(3, 1fr);">
            <div class="form-group">
                <label>Entry Price</label>
                <input type="number" step="0.00001" name="entry_price" class="form-control" value="<%= trade.entry_price %>">
            </div>
            <div class="form-group">
                <label>Stop Loss</label>
                <input type="number" step="0.00001" name="stop_loss" class="form-control" value="<%= trade.stop_loss %>">
            </div>
            <div class="form-group">
                <label>Take Profit</label>
                <input type="number" step="0.00001" name="take_profit" class="form-control" value="<%= trade.take_profit %>">
            </div>
        </div>

        <div class="grid-2" style="grid-template-columns: repeat(3, 1fr);">
            <div class="form-group">
                <label>Risk Amount ($)</label>
                <input type="number" step="0.01" name="risk" class="form-control" value="<%= trade.risk %>">
            </div>
            <div class="form-group">
                <label>Result</label>
                <select name="result" class="form-control">
                    <option value="BE" <%= trade.result === 'BE' ? 'selected' : '' %>>BE</option>
                    <option value="win" <%= trade.result === 'win' ? 'selected' : '' %>>Win</option>
                    <option value="loss" <%= trade.result === 'loss' ? 'selected' : '' %>>Loss</option>
                </select>
            </div>
            <div class="form-group">
                <label>PnL ($)</label>
                <input type="number" step="0.01" name="pnl" class="form-control" value="<%= trade.pnl %>">
            </div>
        </div>

        <div class="form-group">
            <label>Current Balance ($)</label>
            <input type="number" step="0.01" name="balance" class="form-control" value="<%= trade.balance %>">
        </div>

        <div class="form-group">
            <label>Notes</label>
            <textarea name="note" class="form-control" rows="3"><%= trade.note %></textarea>
        </div>

        <div class="form-group">
            <label>Screenshot</label>
            <% if (trade.screenshot) { %>
                <div style="margin-bottom: 10px;">
                    <img src="<%= trade.screenshot %>" alt="Trade Screenshot" style="max-width: 200px; border-radius: 8px;">
                </div>
            <% } %>
            <input type="file" name="screenshot" class="form-control">
        </div>

        <div style="margin-top: 1.5rem;">
            <button type="submit" class="btn btn-primary">Update Trade</button>
            <a href="/trades" class="btn btn-secondary" style="background: #e2e8f0; color: #475569;">Cancel</a>
        </div>
    </form>
</div>
