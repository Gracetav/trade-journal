<div class="max-w-2xl mx-auto">
    <div class="mb-8 flex items-center gap-4">
        <a href="/real-accounts" class="w-10 h-10 flex items-center justify-center bg-white dark:bg-slate-800 rounded-xl shadow-sm border border-slate-100 dark:border-slate-700 text-slate-500 hover:text-blue-600 transition-all">
            <i data-lucide="chevron-left" class="w-6 h-6"></i>
        </a>
        <h1 class="text-3xl font-black text-slate-800 dark:text-white tracking-tight">Edit Akun Real</h1>
    </div>

    <div class="bg-white dark:bg-slate-800 p-8 rounded-[2.5rem] shadow-xl border border-slate-100 dark:border-slate-700">
        <form action="/real-accounts/edit/<%= account.id %>" method="POST" class="space-y-6">
            <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                <div class="space-y-2">
                    <label class="text-xs font-black text-slate-400 uppercase tracking-widest ml-1">Nama Broker</label>
                    <input type="text" name="broker_name" value="<%= account.broker_name %>" required 
                        class="w-full px-5 py-4 bg-slate-50 dark:bg-slate-900 border-none rounded-2xl focus:ring-2 ring-blue-500/50 outline-none font-bold text-slate-700 dark:text-slate-200">
                </div>
                <div class="space-y-2">
                    <label class="text-xs font-black text-slate-400 uppercase tracking-widest ml-1">Account ID / Login</label>
                    <input type="text" name="account_login_id" value="<%= account.account_login_id %>" required
                        class="w-full px-5 py-4 bg-slate-50 dark:bg-slate-900 border-none rounded-2xl focus:ring-2 ring-blue-500/50 outline-none font-bold text-slate-700 dark:text-slate-200">
                </div>
            </div>

            <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                <div class="space-y-2">
                    <label class="text-xs font-black text-slate-400 uppercase tracking-widest ml-1">Tipe Akun</label>
                    <select name="account_type" class="w-full px-5 py-4 bg-slate-50 dark:bg-slate-900 border-none rounded-2xl focus:ring-2 ring-blue-500/50 outline-none font-bold text-slate-700 dark:text-slate-200">
                        <option value="standard" <%= account.account_type === 'standard' ? 'selected' : '' %>>Standard</option>
                        <option value="cent" <%= account.account_type === 'cent' ? 'selected' : '' %>>Cent</option>
                        <option value="pro" <%= account.account_type === 'pro' ? 'selected' : '' %>>Pro</option>
                        <option value="no-spread" <%= account.account_type === 'no-spread' ? 'selected' : '' %>>No-Spread</option>
                        <option value="raw-spread" <%= account.account_type === 'raw-spread' ? 'selected' : '' %>>Raw Spread</option>
                        <option value="demo" <%= account.account_type === 'demo' ? 'selected' : '' %>>Demo</option>
                    </select>
                </div>
                <div class="space-y-2">
                    <label class="text-xs font-black text-slate-400 uppercase tracking-widest ml-1">Leverage</label>
                    <div class="relative">
                        <span class="absolute left-5 top-1/2 -translate-y-1/2 text-slate-400 font-bold">1:</span>
                        <input type="number" name="leverage" value="<%= account.leverage %>" class="w-full pl-10 pr-5 py-4 bg-slate-50 dark:bg-slate-900 border-none rounded-2xl focus:ring-2 ring-blue-500/50 outline-none font-bold text-slate-700 dark:text-slate-200">
                    </div>
                </div>
            </div>

            <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                <div class="space-y-2">
                    <label class="text-xs font-black text-slate-400 uppercase tracking-widest ml-1">Platform</label>
                    <select name="platform" class="w-full px-5 py-4 bg-slate-50 dark:bg-slate-900 border-none rounded-2xl focus:ring-2 ring-blue-500/50 outline-none font-bold text-slate-700 dark:text-slate-200">
                        <option value="MT5" <%= account.platform === 'MT5' ? 'selected' : '' %>>MetaTrader 5</option>
                        <option value="MT4" <%= account.platform === 'MT4' ? 'selected' : '' %>>MetaTrader 4</option>
                        <option value="cTrader" <%= account.platform === 'cTrader' ? 'selected' : '' %>>cTrader</option>
                    </select>
                </div>
                <div class="space-y-2">
                    <label class="text-xs font-black text-slate-400 uppercase tracking-widest ml-1">Saldo Saat Ini ($)</label>
                    <input type="number" step="0.01" name="balance" value="<%= account.balance %>" class="w-full px-5 py-4 bg-slate-50 dark:bg-slate-900 border-none rounded-2xl focus:ring-2 ring-blue-500/50 outline-none font-bold text-slate-700 dark:text-slate-200">
                </div>
            </div>

            <div class="space-y-2">
                <label class="text-xs font-black text-slate-400 uppercase tracking-widest ml-1">Status</label>
                <select name="status" class="w-full px-5 py-4 bg-slate-50 dark:bg-slate-900 border-none rounded-2xl focus:ring-2 ring-blue-500/50 outline-none font-bold text-slate-700 dark:text-slate-200">
                    <option value="active" <%= account.status === 'active' ? 'selected' : '' %>>Active</option>
                    <option value="archived" <%= account.status === 'archived' ? 'selected' : '' %>>Archived</option>
                </select>
            </div>

            <div class="pt-4">
                <button type="submit" class="w-full py-4 bg-blue-600 hover:bg-blue-700 text-white font-black rounded-2xl shadow-xl shadow-blue-500/20 transition-all transform hover:-translate-y-1">
                    UPDATE AKUN REAL
                </button>
            </div>
        </form>
    </div>
</div>
