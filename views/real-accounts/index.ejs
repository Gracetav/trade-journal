<div class="flex items-center justify-between mb-8">
    <div>
        <h1 class="text-3xl font-black text-slate-800 dark:text-white tracking-tight">Akun Real</h1>
        <p class="text-slate-500 dark:text-slate-400 font-medium">Kelola akun trading personal Anda secara profesional</p>
    </div>
    <a href="/real-accounts/add" class="flex items-center gap-2 px-6 py-3 bg-blue-600 hover:bg-blue-700 text-white font-bold rounded-2xl shadow-lg shadow-blue-500/20 transition-all transform hover:-translate-y-1">
        <i data-lucide="plus" class="w-5 h-5"></i>
        Tambah Akun Real
    </a>
</div>

<div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
    <% if (accounts.length === 0) { %>
        <div class="col-span-full py-20 text-center bg-white dark:bg-slate-800 rounded-[2.5rem] border border-slate-100 dark:border-slate-700">
            <div class="w-20 h-20 bg-slate-50 dark:bg-slate-900 rounded-3xl flex items-center justify-center mx-auto mb-4">
                <i data-lucide="database" class="w-10 h-10 text-slate-300"></i>
            </div>
            <h3 class="text-xl font-bold text-slate-800 dark:text-white mb-2">Belum ada akun real</h3>
            <p class="text-slate-500 mb-6">Mulai catat portofolio trading personal Anda sekarang</p>
            <a href="/real-accounts/add" class="text-blue-600 font-bold hover:underline">Tambah Akun Pertama &rarr;</a>
        </div>
    <% } %>

    <% accounts.forEach(account => { %>
    <div class="bg-white dark:bg-slate-800 p-6 rounded-[2.5rem] shadow-xl border border-slate-100 dark:border-slate-700 hover:border-blue-500/30 transition-all group">
        <div class="flex items-start justify-between mb-6">
            <div class="flex items-center gap-4">
                <div class="w-12 h-12 bg-blue-50 dark:bg-blue-900/30 rounded-2xl flex items-center justify-center text-blue-600">
                    <i data-lucide="shield-check" class="w-6 h-6"></i>
                </div>
                <div>
                    <h3 class="font-black text-slate-800 dark:text-white leading-tight uppercase"><%= account.broker_name %></h3>
                    <p class="text-xs font-bold text-slate-400">ID: <%= account.account_login_id %></p>
                </div>
            </div>
            <span class="px-3 py-1 rounded-full text-[10px] font-black uppercase tracking-widest <%= account.status === 'active' ? 'bg-emerald-100 text-emerald-600' : 'bg-slate-100 text-slate-500' %>">
                <%= account.status %>
            </span>
        </div>

        <div class="grid grid-cols-2 gap-4 mb-6">
            <div class="p-4 bg-slate-50 dark:bg-slate-900/50 rounded-2xl">
                <p class="text-[10px] font-black text-slate-400 mb-1 uppercase tracking-tighter">Type</p>
                <p class="text-sm font-bold text-slate-700 dark:text-slate-200 capitalize"><%= account.account_type %></p>
            </div>
            <div class="p-4 bg-slate-50 dark:bg-slate-900/50 rounded-2xl">
                <p class="text-[10px] font-black text-slate-400 mb-1 uppercase tracking-tighter">Leverage</p>
                <p class="text-sm font-bold text-slate-700 dark:text-slate-200">1:<%= account.leverage %></p>
            </div>
            <div class="p-4 bg-slate-50 dark:bg-slate-900/50 rounded-2xl">
                <p class="text-[10px] font-black text-slate-400 mb-1 uppercase tracking-tighter">Platform</p>
                <p class="text-sm font-bold text-slate-700 dark:text-slate-200 uppercase"><%= account.platform %></p>
            </div>
            <div class="p-4 bg-slate-50 dark:bg-slate-900/50 rounded-2xl">
                <p class="text-[10px] font-black text-slate-400 mb-1 uppercase tracking-tighter">Currency</p>
                <p class="text-sm font-bold text-slate-700 dark:text-slate-200 uppercase"><%= account.currency %></p>
            </div>
        </div>

        <div class="mb-6">
            <p class="text-xs font-bold text-slate-400 mb-1">Current Balance</p>
            <h4 class="text-2xl font-black text-slate-800 dark:text-white">$<%= parseFloat(account.balance).toLocaleString() %></h4>
        </div>

        <div class="flex items-center gap-2 pt-4 border-t border-slate-50 dark:border-slate-700/50">
            <a href="/real-accounts/edit/<%= account.id %>" class="flex-1 py-3 bg-slate-100 dark:bg-slate-700 hover:bg-slate-200 dark:hover:bg-slate-600 text-slate-600 dark:text-slate-300 font-bold rounded-xl text-xs text-center transition-all">
                EDIT
            </a>
            <form action="/real-accounts/delete/<%= account.id %>" method="POST" class="delete-form">
                <button type="submit" class="w-12 h-12 flex items-center justify-center bg-rose-50 dark:bg-rose-900/20 text-rose-500 hover:bg-rose-100 dark:hover:bg-rose-900/40 rounded-xl transition-all">
                    <i data-lucide="trash-2" class="w-5 h-5"></i>
                </button>
            </form>
        </div>
    </div>
    <% }) %>
</div>
