<div class="max-w-[1600px] mx-auto p-4 lg:p-6">
    <!-- Header & Navigation -->
    <div class="flex flex-col md:flex-row md:items-center justify-between gap-6 mb-10">
        <div>
            <h1 class="text-3xl font-black text-slate-800 dark:text-slate-100 tracking-tight flex items-center gap-3">
                <div class="w-10 h-10 bg-blue-600 rounded-2xl flex items-center justify-center shadow-xl shadow-blue-500/20">
                    <i data-lucide="calendar" class="w-6 h-6 text-white text-bold"></i>
                </div>
                Trading Calendar
            </h1>
            <p class="text-slate-400 font-bold mt-1 uppercase text-[10px] tracking-widest pl-1">Chronological Performance Tracking</p>
        </div>

        <div class="flex items-center gap-2 bg-white dark:bg-slate-800 p-2 rounded-3xl shadow-sm border border-slate-100 dark:border-slate-700">
            <% 
                let prevMonth = month - 1; let prevYear = year;
                if (prevMonth === 0) { prevMonth = 12; prevYear--; }
                let nextMonth = month + 1; let nextYear = year;
                if (nextMonth === 13) { nextMonth = 1; nextYear++; }
            %>
            <a href="/calendar?month=<%= prevMonth %>&year=<%= prevYear %>" class="p-3 hover:bg-slate-50 dark:hover:bg-slate-900 rounded-2xl text-slate-400 hover:text-blue-600 transition-all">
                <i data-lucide="chevron-left" class="w-5 h-5"></i>
            </a>
            <div class="px-6 py-2 text-center min-w-[150px]">
                <p class="text-sm font-black text-slate-800 dark:text-slate-100 uppercase tracking-tighter"><%= monthName %> <%= year %></p>
            </div>
            <a href="/calendar?month=<%= nextMonth %>&year=<%= nextYear %>" class="p-3 hover:bg-slate-50 dark:hover:bg-slate-900 rounded-2xl text-slate-400 hover:text-blue-600 transition-all">
                <i data-lucide="chevron-right" class="w-5 h-5"></i>
            </a>
        </div>
    </div>

    <!-- Stats Quick Glance -->
    <div class="grid grid-cols-2 lg:grid-cols-5 gap-4 mb-10">
        <div class="bg-white dark:bg-slate-800 p-5 rounded-[2rem] border border-slate-100 dark:border-slate-700 shadow-sm">
            <p class="text-[10px] font-black text-slate-400 uppercase tracking-widest mb-1">Total Trades</p>
            <h3 class="text-2xl font-black text-slate-800 dark:text-slate-100"><%= totalTrades %></h3>
        </div>
        <div class="bg-white dark:bg-slate-800 p-5 rounded-[2rem] border border-slate-100 dark:border-slate-700 shadow-sm">
            <p class="text-[10px] font-black text-slate-400 uppercase tracking-widest mb-1">Monthly P&L</p>
            <h3 class="text-2xl font-black <%= totalPnL >= 0 ? 'text-emerald-500' : 'text-rose-500' %>">
                <%= totalPnL >= 0 ? '+' : '-' %>$<%= Math.abs(totalPnL).toLocaleString() %>
            </h3>
        </div>
        <div class="bg-white dark:bg-slate-800 p-5 rounded-[2rem] border border-slate-100 dark:border-slate-700 shadow-sm">
            <p class="text-[10px] font-black text-slate-400 uppercase tracking-widest mb-1">Best Day</p>
            <h3 class="text-2xl font-black text-emerald-400">+$<%= Number(bestDay).toLocaleString() %></h3>
        </div>
        <div class="bg-white dark:bg-slate-800 p-5 rounded-[2rem] border border-slate-100 dark:border-slate-700 shadow-sm">
            <p class="text-[10px] font-black text-slate-400 uppercase tracking-widest mb-1">Worst Day</p>
            <h3 class="text-2xl font-black text-rose-400">-$<%= Math.abs(worstDay).toLocaleString() %></h3>
        </div>
        <div class="bg-white dark:bg-slate-800 p-5 rounded-[2rem] border border-slate-100 dark:border-slate-700 shadow-sm col-span-2 lg:col-span-1">
            <p class="text-[10px] font-black text-slate-400 uppercase tracking-widest mb-1">Win Rate</p>
            <h3 class="text-2xl font-black text-blue-500"><%= winRate %>%</h3>
        </div>
    </div>

    <!-- Calendar Grid -->
    <div class="bg-white dark:bg-slate-800 rounded-[2.5rem] shadow-2xl border border-slate-100 dark:border-slate-700 overflow-hidden">
        <!-- Weekday Headers -->
        <div class="grid grid-cols-7 border-b border-slate-100 dark:border-slate-700">
            <% ['MON', 'TUE', 'WED', 'THU', 'FRI', 'SAT', 'SUN'].forEach(day => { %>
                <div class="py-4 text-center text-[10px] font-black text-slate-400 uppercase tracking-widest border-r last:border-0 border-slate-50 dark:border-slate-700/50">
                    <%= day %>
                </div>
            <% }) %>
        </div>

        <!-- Days Grid -->
        <div class="grid grid-cols-7">
            <% 
                const firstDayOfMonth = new Date(year, month - 1, 1).getDay(); // 0 is Sunday
                const daysInMonth = new Date(year, month, 0).getDate();
                const startingPadding = firstDayOfMonth === 0 ? 6 : firstDayOfMonth - 1; // Align Mon-Sun
                const prevMonthDays = new Date(year, month - 1, 0).getDate();
            %>

            <!-- Padding for previous month -->
            <% for (let i = startingPadding - 1; i >= 0; i--) { %>
                <div class="aspect-square p-2 border-r border-b border-slate-50 dark:border-slate-700/50 opacity-20 bg-slate-50/50 dark:bg-slate-900/10">
                    <span class="text-xs font-bold text-slate-400"><%= prevMonthDays - i %></span>
                </div>
            <% } %>

            <!-- Real days -->
            <% for (let day = 1; day <= daysInMonth; day++) { 
                const dateKey = `${year}-${String(month).padStart(2, '0')}-${String(day).padStart(2, '0')}`;
                const dayStat = statsMap[dateKey];
                const isToday = new Date().toISOString().split('T')[0] === dateKey;
            %>
                <div class="aspect-square p-3 border-r border-b border-slate-50 dark:border-slate-700/50 relative group transition-all duration-300 hover:bg-slate-50 dark:hover:bg-slate-900/50 <%= dayStat ? (dayStat.pnl >= 0 ? 'bg-emerald-50/30' : 'bg-rose-50/30') : '' %>">
                    <div class="flex items-start justify-between">
                        <span class="text-sm font-black <%= isToday ? 'w-7 h-7 bg-blue-600 text-white rounded-lg flex items-center justify-center -mt-1 -ml-1 shadow-lg shadow-blue-500/30' : 'text-slate-400' %> font-mono">
                            <%= String(day).padStart(2, '0') %>
                        </span>
                    </div>

                    <% if (dayStat) { %>
                        <div class="mt-auto flex flex-col items-center justify-center py-2">
                            <p class="text-sm lg:text-base font-black <%= dayStat.pnl >= 0 ? 'text-emerald-600' : 'text-rose-600' %> tracking-tighter">
                                <%= dayStat.pnl >= 0 ? '+' : '-' %>$<%= Math.abs(dayStat.pnl).toLocaleString() %>
                            </p>
                            <div class="flex items-center gap-1.5 mt-1">
                                <span class="text-[9px] font-bold py-0.5 px-2 rounded-full uppercase <%= dayStat.pnl >= 0 ? 'bg-emerald-100 text-emerald-700 dark:bg-emerald-900/30 dark:text-emerald-400' : 'bg-rose-100 text-rose-700 dark:bg-rose-900/30 dark:text-rose-400' %>">
                                    <%= dayStat.count %> Trades
                                </span>
                            </div>
                        </div>
                    <% } %>
                </div>
            <% } %>

            <!-- Padding for next month to complete the row if needed -->
            <% 
                const remainingCells = 7 - ((startingPadding + daysInMonth) % 7);
                if (remainingCells < 7) {
                    for (let i = 1; i <= remainingCells; i++) {
            %>
                <div class="aspect-square p-2 border-r border-b border-slate-50 dark:border-slate-700/50 opacity-20 bg-slate-50/50 dark:bg-slate-900/10 last:border-r-0">
                    <span class="text-xs font-bold text-slate-400"><%= String(i).padStart(2, '0') %></span>
                </div>
            <%      } 
                } 
            %>
        </div>
    </div>
</div>
