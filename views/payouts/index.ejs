<div class="bg-white dark:bg-slate-800 rounded-2xl shadow-sm border border-slate-100 dark:border-slate-700 overflow-hidden">
    <div class="px-6 py-5 border-b border-slate-100 dark:border-slate-700 flex justify-between items-center bg-slate-50/50 dark:bg-slate-800/50">
        <h2 class="text-lg font-bold text-slate-800 dark:text-slate-100">Payout History</h2>
        <a href="/payouts/add" class="bg-blue-600 hover:bg-blue-700 text-white font-bold py-2 px-6 rounded-xl transition-all shadow-lg shadow-blue-500/20 text-sm">
            + Request Payout
        </a>
    </div>

    <div class="overflow-x-auto">
        <table class="w-full text-left border-collapse">
            <thead>
                <tr class="bg-slate-50 dark:bg-slate-900/50 border-b border-slate-100 dark:border-slate-700">
                    <th class="px-6 py-4 text-xs font-bold text-slate-500 dark:text-slate-400 uppercase tracking-wider">Account Information</th>
                    <th class="px-6 py-4 text-xs font-bold text-slate-500 dark:text-slate-400 uppercase tracking-wider text-right">Balance</th>
                    <th class="px-6 py-4 text-xs font-bold text-slate-500 dark:text-slate-400 uppercase tracking-wider text-right">Amount</th>
                    <th class="px-6 py-4 text-xs font-bold text-slate-500 dark:text-slate-400 uppercase tracking-wider text-center">Certificate</th>
                    <th class="px-6 py-4 text-xs font-bold text-slate-500 dark:text-slate-400 uppercase tracking-wider text-center">Status</th>
                    <th class="px-6 py-4 text-xs font-bold text-slate-500 dark:text-slate-400 uppercase tracking-wider text-right">Actions</th>
                </tr>
            </thead>
            <tbody class="divide-y divide-slate-100 dark:divide-slate-700">
                <% payouts.forEach(p => { %>
                <tr class="hover:bg-slate-50 dark:hover:bg-slate-700/50 transition-colors">
                    <td class="px-6 py-4">
                        <div class="font-bold text-slate-800 dark:text-slate-100 tracking-tight"><%= p.propfirm_name %></div>
                        <div class="text-[10px] text-slate-400 font-bold uppercase tracking-tight mt-0.5">
                            ID: #<%= p.account_login_id || 'N/A' %> • <%= p.account_name %>
                        </div>
                    </td>
                    <td class="px-6 py-4 text-right">
                        <span class="text-xs font-medium text-slate-500 dark:text-slate-400">$<%= p.account_balance ? Number(p.account_balance).toLocaleString() : '-' %></span>
                    </td>
                    <td class="px-6 py-4 text-right">
                        <div class="font-bold text-emerald-500 tracking-tight">$<%= Number(p.amount).toLocaleString() %></div>
                        <div class="text-[9px] text-slate-400 uppercase font-bold"><%= moment(p.request_date).format('MMM DD, YYYY') %></div>
                    </td>
                    <td class="px-6 py-4 text-center">
                        <% if (p.certificate) { %>
                            <div class="flex justify-center">
                                <img src="<%= p.certificate %>" 
                                     class="w-10 h-10 object-cover rounded-lg border-2 border-slate-200 dark:border-slate-700 cursor-pointer hover:scale-110 transition-transform shadow-sm" 
                                     onclick="previewImage('<%= p.certificate %>')"
                                     alt="Cert">
                            </div>
                        <% } else { %>
                            <span class="text-slate-300 dark:text-slate-600 text-[10px] font-bold uppercase italic">No File</span>
                        <% } %>
                    </td>
                    <td class="px-6 py-4 text-center">
                        <span class="px-2.5 py-1 rounded text-[10px] font-bold uppercase tracking-wider <%= p.status === 'approved' ? 'bg-emerald-100 text-emerald-700 dark:bg-emerald-900/30 dark:text-emerald-400' : 'bg-amber-100 text-amber-700 dark:bg-amber-900/30 dark:text-amber-400' %>">
                            <%= p.status %>
                        </span>
                    </td>
                    <td class="px-6 py-4 text-right">
                        <div class="flex justify-end gap-2 text-[18px]">
                            <a href="/payouts/<%= p.id %>/edit" class="p-2 text-slate-400 hover:text-blue-600 bg-slate-100 dark:bg-slate-700 hover:bg-blue-50 dark:hover:bg-blue-900/30 rounded-lg transition-all" title="Edit">
                                ✏️
                            </a>
                            <form action="/payouts/<%= p.id %>?_method=DELETE" method="POST" class="delete-form">
                                <button type="submit" class="p-2 text-slate-400 hover:text-rose-600 bg-slate-100 dark:bg-slate-700 hover:bg-rose-50 dark:hover:bg-rose-900/30 rounded-lg transition-all" title="Delete">
                                    🗑️
                                </button>
                            </form>
                        </div>
                    </td>
                </tr>
                <% }) %>
                <% if (payouts.length === 0) { %>
                <tr>
                    <td colspan="6" class="px-6 py-12 text-center text-slate-400 italic">No payout history found.</td>
                </tr>
                <% } %>
            </tbody>
        </table>
    </div>
</div>

<script>
function previewImage(url) {
    const isDark = document.documentElement.classList.contains('dark');
    Swal.fire({
        imageUrl: url,
        imageAlt: 'Payout Certificate',
        width: '600px',
        showConfirmButton: false,
        background: isDark ? '#1e293b' : '#fff',
        color: isDark ? '#f8fafc' : '#1e293b',
        padding: '1rem',
        showCloseButton: true,
        customClass: {
            popup: 'rounded-2xl border border-slate-200 dark:border-slate-700 shadow-2xl',
            image: 'rounded-xl shadow-lg border border-slate-100 dark:border-slate-700'
        }
    });
}
</script>
