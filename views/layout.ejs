<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Trade Journal Pro | Premium Trading Analytics</title>
    <link rel="stylesheet" href="/css/style.css">
    <!-- Lucide Icons for lightweight icon solution -->
    <script src="https://unpkg.com/lucide@latest"></script>
</head>
<body>
    <div class="app-container">
        <!-- Sidebar -->
        <aside class="sidebar">
            <a href="/" class="logo">
                <i data-lucide="line-chart"></i>
                <span>TradeJournal <span style="font-weight: 400; opacity: 0.7">Pro</span></span>
            </a>
            
            <nav>
                <ul class="nav-links">
                    <li class="nav-item">
                        <a href="/" class="<%= path === '/' ? 'active' : '' %>">
                            <i data-lucide="layout-dashboard"></i>
                            <span>Dashboard</span>
                        </a>
                    </li>
                    <li class="nav-item">
                        <a href="/trades" class="<%= path.startsWith('/trades') ? 'active' : '' %>">
                            <i data-lucide="history"></i>
                            <span>Trades</span>
                        </a>
                    </li>
                    <li class="nav-item">
                        <a href="/accounts" class="<%= path.startsWith('/accounts') ? 'active' : '' %>">
                            <i data-lucide="briefcase"></i>
                            <span>Accounts</span>
                        </a>
                    </li>
                    <li class="nav-item">
                        <a href="/payouts" class="<%= path.startsWith('/payouts') ? 'active' : '' %>">
                            <i data-lucide="wallet"></i>
                            <span>Payouts</span>
                        </a>
                    </li>
                    <li class="nav-item" style="margin-top: auto;">
                        <a href="/logout">
                            <i data-lucide="log-out"></i>
                            <span>Logout</span>
                        </a>
                    </li>
                </ul>
            </nav>
        </aside>

        <!-- Main Content -->
        <main class="main-content">
            <header class="topbar">
                <div class="user-badge">
                    <span class="role-tag">Trader Prop</span>
                    <span><%= username || 'Guest' %></span>
                    <i data-lucide="user-circle"></i>
                </div>
            </header>

            <div class="content-wrapper">
                <%- body %>
            </div>
        </main>
    </div>

    <script>
        // Initialize Lucide icons
        lucide.createIcons();
    </script>
</body>
</html>
