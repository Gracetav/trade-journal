<div class="max-w-4xl mx-auto p-6">
    <div class="mb-10 text-center">
        <h1 class="text-3xl font-black text-slate-800 dark:text-white tracking-tight mb-2">Import MT5 Statement</h1>
        <p class="text-slate-500 dark:text-slate-400 font-medium">Bulk import your trading history from HTML or PDF reports</p>
    </div>

    <% if (error) { %>
        <div class="mb-8 p-4 bg-rose-50 dark:bg-rose-900/20 border border-rose-100 dark:border-rose-800 rounded-2xl text-rose-600 dark:text-rose-400 text-sm font-bold flex items-center gap-3">
            <i data-lucide="alert-circle" class="w-5 h-5"></i>
            <%= error %>
        </div>
    <% } %>

    <!-- Upload Section -->
    <div class="bg-white dark:bg-slate-800 p-8 rounded-[2.5rem] shadow-xl border border-slate-100 dark:border-slate-700 mb-10">
        <form action="/import" method="POST" enctype="multipart/form-data" id="uploadForm">
            <div class="group relative border-2 border-dashed border-slate-200 dark:border-slate-700 rounded-[2rem] p-12 transition-all hover:border-blue-500 hover:bg-blue-50/50 dark:hover:bg-blue-900/10 cursor-pointer text-center" onclick="document.getElementById('fileInput').click()">
                <input type="file" name="report" id="fileInput" class="hidden" accept=".html,.htm,.pdf" onchange="this.form.submit()">
                
                <div class="w-16 h-16 bg-blue-50 dark:bg-blue-900/30 rounded-2xl flex items-center justify-center mx-auto mb-4 group-hover:scale-110 transition-transform">
                    <i data-lucide="file-up" class="w-8 h-8 text-blue-600"></i>
                </div>
                
                <h3 class="text-lg font-bold text-slate-800 dark:text-white mb-1">Click to upload MT5 Statement</h3>
                <p class="text-sm text-slate-400">Drag & drop your .html or .pdf report here</p>
                <div class="mt-4 flex justify-center gap-2">
                    <span class="px-3 py-1 bg-slate-100 dark:bg-slate-900 rounded-full text-[10px] font-black text-slate-500">HTML RECOMMENDED</span>
                    <span class="px-3 py-1 bg-slate-100 dark:bg-slate-900 rounded-full text-[10px] font-black text-slate-500">PDF FALLBACK</span>
                </div>
            </div>
        </form>
    </div>

    <% if (results && results.length > 0) { %>
        <!-- Confirmation Section -->
        <div class="bg-white dark:bg-slate-800 p-8 rounded-[2.5rem] shadow-xl border border-slate-100 dark:border-slate-700">
            <div class="flex items-center justify-between mb-8">
                <div>
                    <h2 class="text-xl font-black text-slate-800 dark:text-white">Detected Trades</h2>
                    <p class="text-sm text-slate-400">We found <%= results.length %> transactions in your file</p>
                </div>
                
                <div class="flex flex-col gap-2">
                    <label class="text-[10px] font-black text-slate-400 uppercase tracking-widest pl-1">Assign to Account</label>
                    <select id="accountSelect" class="bg-slate-50 dark:bg-slate-900 border-none rounded-xl text-sm font-bold px-4 py-2.5 outline-none focus:ring-2 ring-blue-500/50">
                        <% if (accounts && accounts.length > 0) { %>
                            <% accounts.forEach(acc => { %>
                                <option value="<%= acc.id %>"><%= acc.label %></option>
                            <% }) %>
                        <% } else { %>
                            <option value="">(Belum ada akun - Silakan buat terlebih dahulu)</option>
                        <% } %>
                    </select>
                </div>
            </div>

            <div class="overflow-x-auto mb-8">
                <table class="w-full text-left min-w-[800px]">
                    <thead>
                        <tr class="text-[10px] font-black text-slate-400 uppercase tracking-widest border-b border-slate-100 dark:border-slate-700">
                            <th class="px-4 py-4">Symbol</th>
                            <th class="px-4 py-4">Type</th>
                            <th class="px-4 py-4">Lot</th>
                            <th class="px-4 py-4">Close Time</th>
                            <th class="px-4 py-4">Day</th>
                            <th class="px-4 py-4">Exit Price</th>
                            <th class="px-4 py-4">SL</th>
                            <th class="px-4 py-4">TP</th>
                            <th class="px-4 py-4 text-right">Profit</th>
                        </tr>
                    </thead>
                    <tbody class="divide-y divide-slate-100 dark:divide-slate-700">
                        <% results.forEach(trade => { %>
                            <tr>
                                <td class="px-4 py-4 font-bold text-slate-700 dark:text-slate-200"><%= trade.pair %></td>
                                <td class="px-4 py-4">
                                    <span class="px-2 py-1 rounded-lg text-[10px] font-bold <%= trade.type === 'BUY' ? 'bg-emerald-100 text-emerald-700' : 'bg-rose-100 text-rose-700' %>">
                                        <%= trade.type %>
                                    </span>
                                </td>
                                <td class="px-4 py-4 text-slate-500 font-medium"><%= trade.volume %></td>
                                <td class="px-4 py-4 text-[11px] text-slate-500 font-medium"><%= trade.close_time %></td>
                                <td class="px-4 py-4 text-[11px] text-slate-500 font-medium"><%= trade.day %></td>
                                <td class="px-4 py-4 text-[11px] text-slate-600 font-bold"><%= trade.exit_price %></td>
                                <td class="px-4 py-4 text-[11px] text-rose-400 font-medium"><%= trade.sl %></td>
                                <td class="px-4 py-4 text-[11px] text-emerald-400 font-medium"><%= trade.tp %></td>
                                <td class="px-4 py-4 text-right font-black <%= trade.pnl >= 0 ? 'text-emerald-500' : 'text-rose-500' %>">
                                    $<%= trade.pnl.toLocaleString() %>
                                </td>
                            </tr>
                        <% }) %>
                    </tbody>
                </table>
            </div>

            <button onclick="saveTrades()" id="saveBtn" class="w-full py-4 bg-blue-600 hover:bg-blue-700 text-white font-black rounded-2xl shadow-xl shadow-blue-500/20 transition-all flex items-center justify-center gap-3">
                <i data-lucide="check-circle" class="w-5 h-5"></i>
                SAVE <%= results.length %> TRADES TO JOURNAL
            </button>
        </div>

        <script>
            async function saveTrades() {
                const trades = <%- JSON.stringify(results) %>;
                const account_id = document.getElementById('accountSelect').value;
                const btn = document.getElementById('saveBtn');
                
                btn.disabled = true;
                btn.innerHTML = '<i class="animate-spin w-5 h-5 border-2 border-white border-t-transparent rounded-full"></i> SAVING...';

                if (!account_id || account_id === "") {
                    Swal.fire({
                        title: 'Akun Belum Dipilih',
                        text: 'Silakan pilih akun trading terlebih dahulu. Jika belum tersedia, silakan buat di menu Akun Real atau Prop Accounts.',
                        icon: 'warning',
                        confirmButtonColor: '#2563eb'
                    });
                    btn.disabled = false;
                    btn.innerHTML = '<i data-lucide="check-circle" class="w-5 h-5"></i> SAVE ' + trades.length + ' TRADES TO JOURNAL';
                    if (window.lucide) lucide.createIcons();
                    return;
                }

                try {
                    const res = await fetch('/import/save', {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify({ trades, account_id })
                    });
                    
                    const data = await res.json();
                    if (data.success) {
                        Swal.fire({
                            title: 'Success!',
                            text: data.message,
                            icon: 'success',
                            confirmButtonColor: '#2563eb'
                        }).then(() => {
                            window.location.href = '/trades';
                        });
                    } else {
                        Swal.fire('Error', data.message || 'Gagal menyimpan data', 'error');
                        btn.disabled = false;
                        btn.innerHTML = '<i data-lucide="check-circle" class="w-5 h-5"></i> SAVE ' + trades.length + ' TRADES TO JOURNAL';
                        if (window.lucide) lucide.createIcons();
                    }
                } catch (err) {
                    Swal.fire('Error', 'Gagal menghubungkan ke server', 'error');
                    btn.disabled = false;
                    btn.innerHTML = '<i data-lucide="check-circle" class="w-5 h-5"></i> SAVE ' + trades.length + ' TRADES TO JOURNAL';
                    if (window.lucide) lucide.createIcons();
                }
            }
        </script>
    <% } %>
</div>
