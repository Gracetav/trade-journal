<!-- Global Business Stats -->
<div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6 mb-8">
    <div class="bg-white dark:bg-slate-800 p-6 rounded-2xl shadow-sm border border-slate-100 dark:border-slate-700 transition-all hover:shadow-md relative overflow-hidden group">
        <div class="absolute top-0 right-0 p-3 opacity-10 group-hover:opacity-20 transition-opacity">
            <i data-lucide="banknote" class="w-12 h-12"></i>
        </div>
        <p class="text-[10px] font-bold text-slate-400 dark:text-slate-500 uppercase tracking-[0.2em] mb-1">Net Operating Profit</p>
        <h3 class="text-3xl font-black <%= stats.netProfit >= 0 ? 'text-emerald-500' : 'text-rose-500' %> tracking-tight">
            $<%= Number(stats.netProfit).toLocaleString(undefined, {minimumFractionDigits: 2, maximumFractionDigits: 2}) %>
        </h3>
        <p class="text-xs font-medium text-slate-400 mt-2 flex items-center gap-1">
            <span class="<%= stats.totalROI >= 0 ? 'text-emerald-500' : 'text-rose-500' %> font-bold"><%= stats.totalROI %>%</span> ROI Overall
        </p>
    </div>

    <div class="bg-white dark:bg-slate-800 p-6 rounded-2xl shadow-sm border border-slate-100 dark:border-slate-700 transition-all hover:shadow-md relative overflow-hidden group">
        <div class="absolute top-0 right-0 p-3 opacity-10 group-hover:opacity-20 transition-opacity">
            <i data-lucide="target" class="w-12 h-12"></i>
        </div>
        <p class="text-[10px] font-bold text-slate-400 dark:text-slate-500 uppercase tracking-[0.2em] mb-1">Winrate & Performance</p>
        <h3 class="text-3xl font-black text-blue-600 dark:text-blue-400 tracking-tight"><%= stats.winrate %>%</h3>
        <p class="text-xs font-medium text-slate-400 mt-2 flex items-center gap-1">
            Total PnL: <span class="<%= stats.totalPnL >= 0 ? 'text-emerald-500' : 'text-rose-500' %> font-bold">$<%= Number(stats.totalPnL).toLocaleString() %></span>
        </p>
    </div>

    <div class="bg-white dark:bg-slate-800 p-6 rounded-2xl shadow-sm border border-slate-100 dark:border-slate-700 transition-all hover:shadow-md relative overflow-hidden group">
        <div class="absolute top-0 right-0 p-3 opacity-10 group-hover:opacity-20 transition-opacity">
            <i data-lucide="layers" class="w-12 h-12"></i>
        </div>
        <p class="text-[10px] font-bold text-slate-400 dark:text-slate-500 uppercase tracking-[0.2em] mb-1">Portfolio Composition</p>
        <div class="flex items-end gap-2 mb-3">
            <h3 class="text-3xl font-black text-slate-800 dark:text-slate-100 tracking-tight"><%= stats.totalAccounts %></h3>
            <span class="text-xs font-bold text-slate-400 mb-1.5 uppercase">Total Accounts</span>
        </div>
        
        <div class="grid grid-cols-2 gap-y-2 pt-3 border-t border-slate-50 dark:border-slate-700/50">
            <div class="flex flex-col">
                <span class="text-[10px] font-bold text-slate-400 uppercase tracking-tighter">Funded</span>
                <span class="text-sm font-black text-emerald-500"><%= stats.fundedAccounts %></span>
            </div>
            <div class="flex flex-col">
                <span class="text-[10px] font-bold text-slate-400 uppercase tracking-tighter">Evaluation</span>
                <span class="text-sm font-black text-blue-500"><%= stats.evalAccounts %></span>
            </div>
            <div class="flex flex-col">
                <span class="text-[10px] font-bold text-slate-400 uppercase tracking-tighter">Breached</span>
                <span class="text-sm font-black text-rose-500"><%= stats.breachedAccounts %></span>
            </div>
            <div class="flex flex-col">
                <span class="text-[10px] font-bold text-slate-400 uppercase tracking-tighter">Active</span>
                <span class="text-sm font-black text-slate-800 dark:text-slate-100"><%= stats.activeAccounts %></span>
            </div>
        </div>
    </div>

    <div class="bg-white dark:bg-slate-800 p-6 rounded-2xl shadow-sm border border-slate-100 dark:border-slate-700 transition-all hover:shadow-md relative overflow-hidden group">
        <div class="absolute top-0 right-0 p-3 opacity-10 group-hover:opacity-20 transition-opacity">
            <i data-lucide="award" class="w-12 h-12"></i>
        </div>
        <p class="text-[10px] font-bold text-slate-400 dark:text-slate-500 uppercase tracking-[0.2em] mb-1">Total Payouts</p>
        <div class="flex items-end gap-2 mb-3">
            <h3 class="text-3xl font-black text-emerald-500 tracking-tight">$<%= Number(stats.totalPayout).toLocaleString() %></h3>
            <span class="text-xs font-bold text-slate-400 mb-1.5 uppercase">All Time</span>
        </div>

        <div class="grid grid-cols-2 gap-y-2 pt-3 border-t border-slate-50 dark:border-slate-700/50">
            <div class="flex flex-col text-left">
                <span class="text-[10px] font-bold text-slate-400 uppercase tracking-tighter">This Month</span>
                <span class="text-sm font-black text-emerald-500">$<%= Number(stats.currentMonthPayout).toLocaleString() %></span>
            </div>
            <div class="flex flex-col text-left">
                <span class="text-[10px] font-bold text-slate-400 uppercase tracking-tighter">Avg Payout</span>
                <span class="text-sm font-black text-emerald-600">$<%= Number(stats.avgPayout).toLocaleString() %></span>
            </div>
            <div class="flex flex-col text-left">
                <span class="text-[10px] font-bold text-slate-400 uppercase tracking-tighter">ATH Payout</span>
                <span class="text-sm font-black text-blue-500">$<%= Number(stats.maxPayout).toLocaleString() %></span>
            </div>
            <div class="flex flex-col text-left">
                <span class="text-[10px] font-bold text-slate-400 uppercase tracking-tighter">Efficiency</span>
                <span class="text-sm font-black text-slate-800 dark:text-slate-100">High</span>
            </div>
        </div>
    </div>
</div>

<!-- Main Intelligence Section -->
<div class="grid grid-cols-1 lg:grid-cols-3 gap-8 mb-8">
    <!-- Equity Curve & Cashflow -->
    <div class="lg:col-span-2 bg-white dark:bg-slate-800 p-6 md:p-8 rounded-2xl shadow-sm border border-slate-100 dark:border-slate-700">
        <div class="flex justify-between items-center mb-8">
            <h2 class="text-lg font-bold text-slate-800 dark:text-slate-100 flex items-center gap-2">
                <i data-lucide="trending-up" class="w-5 h-5 text-blue-500"></i> Prop Firm ROI Curve
            </h2>
            <div class="flex gap-4">
                <div class="flex items-center gap-1.5">
                    <span class="w-2.5 h-2.5 rounded-full bg-blue-500"></span>
                    <span class="text-[10px] font-bold text-slate-400">PAYOUT</span>
                </div>
                <div class="flex items-center gap-1.5">
                    <span class="w-2.5 h-2.5 rounded-full bg-rose-500"></span>
                    <span class="text-[10px] font-bold text-slate-400">SPENDING</span>
                </div>
            </div>
        </div>
        <div class="h-[300px] w-full">
            <canvas id="equityCurveChart"></canvas>
        </div>
    </div>

    <!-- Prop Firm Behavior (Insights) -->
    <div class="bg-white dark:bg-slate-800 rounded-2xl shadow-sm border border-slate-100 dark:border-slate-700 flex flex-col h-full overflow-hidden">
        <div class="p-6 md:p-8 border-b border-slate-50 dark:border-slate-700/50 bg-slate-50/50 dark:bg-slate-800/50">
            <h2 class="text-lg font-bold text-slate-800 dark:text-slate-100 flex items-center gap-2">
                <i data-lucide="award" class="w-5 h-5 text-indigo-500"></i> Top Payout Firms
            </h2>
        </div>
        
        <div class="p-6 md:p-8 flex-grow">
            <div class="space-y-5">
                <% firmStats.slice(0, 4).forEach((firm, index) => { %>
                <div class="group relative flex items-center gap-4 p-3 -mx-3 rounded-xl hover:bg-slate-50 dark:hover:bg-slate-900/50 transition-all">
                    <!-- Rank Badge -->
                    <div class="w-10 h-10 rounded-xl flex items-center justify-center font-black text-sm shrink-0
                        <%= index === 0 ? 'bg-amber-100 text-amber-600 border border-amber-200' : 
                            index === 1 ? 'bg-slate-100 text-slate-500 border border-slate-200' : 
                            index === 2 ? 'bg-orange-100 text-orange-600 border border-orange-200' : 
                            'bg-slate-50 text-slate-400 border border-slate-100 dark:bg-slate-800 dark:border-slate-700' %>">
                        <%= index + 1 %>
                    </div>
                    
                    <div class="flex-grow min-w-0">
                        <div class="flex justify-between items-start">
                            <div>
                                <h4 class="font-bold text-slate-800 dark:text-slate-100 leading-tight truncate"><%= firm.name %></h4>
                                <p class="text-[10px] font-bold text-slate-400 mt-0.5"><%= firm.total_accounts %> Accounts</p>
                            </div>
                            <div class="text-right">
                                <p class="text-sm font-black text-emerald-500">$<%= Number(firm.total_payout).toLocaleString() %></p>
                                <p class="text-[9px] text-slate-400 font-bold uppercase tracking-tighter">Profit Taken</p>
                            </div>
                        </div>
                    </div>
                </div>
                <% }) %>

                <% if (firmStats.length === 0) { %>
                    <div class="text-center py-12">
                        <div class="w-12 h-12 bg-slate-50 dark:bg-slate-900 rounded-full flex items-center justify-center mx-auto mb-3">
                            <i data-lucide="info" class="w-6 h-6 text-slate-300"></i>
                        </div>
                        <p class="text-sm text-slate-400">No firm data tracked yet.</p>
                    </div>
                <% } %>
            </div>
        </div>
        
        <div class="p-4 bg-slate-50/50 dark:bg-slate-900/30 border-t border-slate-50 dark:border-slate-700/50">
            <a href="/accounts" class="flex items-center justify-center gap-2 text-[10px] font-bold text-slate-400 hover:text-indigo-500 transition-colors uppercase tracking-widest">
                Explore All Firms <i data-lucide="chevron-right" class="w-3 h-3"></i>
            </a>
        </div>
    </div>
</div>

<!-- Monthly Business ROI Overview -->
<div class="bg-white dark:bg-slate-800 rounded-2xl shadow-sm border border-slate-100 dark:border-slate-700 mb-8 overflow-hidden">
    <div class="px-6 py-5 border-b border-slate-100 dark:border-slate-700 flex justify-between items-center bg-slate-50/50 dark:bg-slate-800/50">
        <h2 class="text-lg font-bold text-slate-800 dark:text-slate-100 flex items-center gap-2">
            <i data-lucide="calendar" class="w-5 h-5 text-blue-500"></i> Monthly ROI Overview
        </h2>
        <span class="text-xs font-bold text-blue-600 bg-blue-50 dark:bg-blue-900/30 px-3 py-1 rounded-full uppercase tracking-tighter">Performance History</span>
    </div>
    <div class="overflow-x-auto">
        <table class="w-full text-left">
            <thead>
                <tr class="bg-slate-50 dark:bg-slate-900/50 border-b border-slate-100 dark:border-slate-700">
                    <th class="px-6 py-4 text-xs font-bold text-slate-500 dark:text-slate-400 uppercase tracking-wider">Month / Period</th>
                    <th class="px-6 py-4 text-xs font-bold text-slate-500 dark:text-slate-400 uppercase tracking-wider">Net Profit</th>
                    <th class="px-6 py-4 text-xs font-bold text-slate-500 dark:text-slate-400 uppercase tracking-wider text-right">Investment</th>
                    <th class="px-6 py-4 text-xs font-bold text-slate-500 dark:text-slate-400 uppercase tracking-wider text-right">Total Payout</th>
                    <th class="px-6 py-4 text-xs font-bold text-slate-500 dark:text-slate-400 uppercase tracking-wider text-right">ROI (%)</th>
                </tr>
            </thead>
            <tbody class="divide-y divide-slate-100 dark:divide-slate-700">
                <% monthlyROI.forEach(item => { %>
                <tr class="hover:bg-slate-50 dark:hover:bg-slate-700/50 transition-colors">
                    <td class="px-6 py-4">
                        <div class="font-bold text-slate-800 dark:text-slate-100"><%= item.month_label %></div>
                        <div class="text-[10px] text-slate-400 font-bold tracking-tight mt-0.5">Prop Firm Business Performance</div>
                    </td>
                    <td class="px-6 py-4">
                        <span class="text-sm font-black <%= item.net_profit >= 0 ? 'text-emerald-500' : 'text-rose-500' %>">
                            $<%= Number(item.net_profit).toLocaleString() %>
                        </span>
                    </td>
                    <td class="px-6 py-4 text-slate-500 dark:text-slate-400 font-bold text-right">$<%= Number(item.total_spending).toLocaleString() %></td>
                    <td class="px-6 py-4 text-emerald-500 font-black text-right">$<%= Number(item.total_payout).toLocaleString() %></td>
                    <td class="px-6 py-4 text-right">
                        <span class="inline-flex items-center px-2.5 py-1 rounded-lg text-xs font-black <%= item.roi_percent >= 0 ? 'bg-emerald-50 dark:bg-emerald-900/20 text-emerald-600 dark:text-emerald-400' : 'bg-rose-50 dark:bg-rose-900/20 text-rose-600 dark:text-rose-400' %>">
                            <%= item.roi_percent ? Number(item.roi_percent).toFixed(1) : '0.0' %>%
                        </span>
                    </td>
                </tr>
                <% }) %>
                <% if (monthlyROI.length === 0) { %>
                    <tr>
                        <td colspan="5" class="px-6 py-12 text-center text-slate-400 italic">No monthly data available yet. Start tracking your purchases and payouts!</td>
                    </tr>
                <% } %>
            </tbody>
        </table>
    </div>
</div>

<div class="grid grid-cols-1 lg:grid-cols-2 gap-8 mb-12">
