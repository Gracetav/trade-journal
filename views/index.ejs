<div class="page-header">
    <h1 class="page-title">Welcome back, <%= username %></h1>
    <p class="page-subtitle">Here's your trading performance overview for this month.</p>
</div>

<!-- Stats Overview -->
<div class="stats-grid">
    <div class="stat-card">
        <div class="stat-label">Total PnL</div>
        <div class="stat-value <%= stats.totalPnL >= 0 ? 'positive' : 'negative' %>">
            <%= stats.totalPnL >= 0 ? '+' : '' %>$<%= stats.totalPnL.toLocaleString() %>
        </div>
        <div class="stat-change <%= stats.totalPnL >= 0 ? 'positive' : 'negative' %>">
            <i data-lucide="<%= stats.totalPnL >= 0 ? 'trending-up' : 'trending-down' %>" style="width: 14px;"></i>
            <span>Performance Trend</span>
        </div>
    </div>

    <div class="stat-card">
        <div class="stat-label">Win Rate</div>
        <div class="stat-value"><%= stats.winrate %>%</div>
        <div class="progress-bar-small" style="height: 4px; background: #e2e8f0; margin-top: 10px; border-radius: 4px;">
            <div style="width: <%= stats.winrate %>%; height: 100%; background: var(--accent); border-radius: 4px;"></div>
        </div>
    </div>

    <div class="stat-card">
        <div class="stat-label">Total Accounts</div>
        <div class="stat-value"><%= stats.totalAccounts %></div>
        <div class="stat-change" style="color: var(--text-muted)">
            <%= stats.fundedAccounts %> Funded | <%= stats.activeAccounts %> Active
        </div>
    </div>

    <div class="stat-card">
        <div class="stat-label">Total ROI</div>
        <div class="stat-value <%= stats.totalROI >= 0 ? 'positive' : 'negative' %>">
            <%= stats.totalROI %>%
        </div>
        <div class="stat-change" style="color: var(--text-muted)">
            Net Profit: $<%= stats.netProfit.toLocaleString() %>
        </div>
    </div>
</div>

<div style="display: grid; grid-template-columns: 1.6fr 1.4fr; gap: 1.5rem; margin-bottom: 2rem;">
    <!-- Chart Section -->
    <div class="card-table-wrapper" style="padding: 1.5rem;">
        <div class="card-header" style="border-bottom: none; padding: 0 0 1.5rem 0;">
            <h3 class="card-title">Balance Growth</h3>
            <i data-lucide="info" style="color: var(--text-muted); width: 16px;"></i>
        </div>
        <canvas id="growthChart" height="250"></canvas>
    </div>

    <!-- Active Accounts Table -->
    <div class="card-table-wrapper">
        <div class="card-header">
            <h3 class="card-title">Active Accounts</h3>
            <a href="/accounts" class="btn btn-ghost" style="padding: 0.25rem 0.75rem; font-size: 0.75rem;">View All</a>
        </div>
        <table>
            <thead>
                <tr>
                    <th>Firm</th>
                    <th>Size</th>
                    <th>Phase</th>
                    <th>Status</th>
                </tr>
            </thead>
            <tbody>
                <% recentAccounts.filter(a => a.status === 'active').slice(0, 5).forEach(account => { %>
                <tr>
                    <td><strong><%= account.propfirm_name %></strong></td>
                    <td>$<%= Number(account.account_size).toLocaleString() %></td>
                    <td><%= account.phase %></td>
                    <td><span class="badge badge-success"><%= account.status %></span></td>
                </tr>
                <% }) %>
            </tbody>
        </table>
    </div>
</div>

<!-- Recent Payouts Table -->
<div class="card-table-wrapper">
    <div class="card-header">
        <h3 class="card-title">Recent Payouts</h3>
        <a href="/payouts" class="btn btn-primary">Request Payout</a>
    </div>
    <table>
        <thead>
            <tr>
                <th>Date</th>
                <th>Firm</th>
                <th>Account ID</th>
                <th>Amount</th>
                <th>Status</th>
            </tr>
        </thead>
        <tbody>
            <% recentPayouts.slice(0, 5).forEach(payout => { %>
            <tr>
                <td><%= moment(payout.request_date).format('MMM DD, YYYY') %></td>
                <td><%= payout.propfirm_name %></td>
                <td><code>#<%= payout.account_login_id %></code></td>
                <td style="font-weight: 600;">$<%= Number(payout.amount).toLocaleString() %></td>
                <td>
                    <span class="badge badge-<%= payout.status === 'approved' ? 'success' : (payout.status === 'pending' ? 'warning' : 'danger') %>">
                        <%= payout.status %>
                    </span>
                </td>
            </tr>
            <% }) %>
        </tbody>
    </table>
</div>

<!-- Chart.js and Custom Script -->
<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
<script>
    const ctx = document.getElementById('growthChart').getContext('2d');
    
    // Prepare data safely with fallbacks
    const rawData = <%- JSON.stringify(chartData || []) %>;
    const chartLabels = rawData.length > 0 ? rawData.map(c => c.month) : ['No Data'];
    const chartValues = rawData.length > 0 ? rawData.map(c => c.payout) : [0];

    new Chart(ctx, {
        type: 'line',
        data: {
            labels: chartLabels,
            datasets: [{
                label: 'Cumulative Payouts',
                data: chartValues,
                borderColor: '#10b981',
                backgroundColor: 'rgba(16, 185, 129, 0.1)',
                borderWidth: 3,
                tension: 0.4,
                fill: true,
                pointRadius: 4,
                pointBackgroundColor: '#fff',
                pointBorderWidth: 2,
            }]
        },
        options: {
            responsive: true,
            maintainAspectRatio: false,
            plugins: {
                legend: { display: false }
            },
            scales: {
                y: {
                    beginAtZero: true,
                    grid: { color: '#f1f5f9' },
                    ticks: { font: { family: 'Poppins', size: 10 } }
                },
                x: {
                    grid: { display: false },
                    ticks: { font: { family: 'Poppins', size: 10 } }
                }
            }
        }
    });
</script>
