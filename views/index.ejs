<!-- Stats Overview -->
<div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-8">
    <div class="bg-white dark:bg-slate-800 p-6 rounded-2xl shadow-sm border border-slate-100 dark:border-slate-700 transition-all hover:shadow-md">
        <p class="text-sm font-medium text-slate-500 dark:text-slate-400 uppercase tracking-wider mb-2">Total PnL</p>
        <h3 class="text-3xl font-bold <%= stats.totalPnL >= 0 ? 'text-emerald-500' : 'text-rose-500' %>">
            $<%= Number(stats.totalPnL).toLocaleString(undefined, {minimumFractionDigits: 2, maximumFractionDigits: 2}) %>
        </h3>
    </div>
    <div class="bg-white dark:bg-slate-800 p-6 rounded-2xl shadow-sm border border-slate-100 dark:border-slate-700 transition-all hover:shadow-md">
        <p class="text-sm font-medium text-slate-500 dark:text-slate-400 uppercase tracking-wider mb-2">Winrate</p>
        <h3 class="text-3xl font-bold text-blue-600 dark:text-blue-400"><%= stats.winrate %>%</h3>
    </div>
    <div class="bg-white dark:bg-slate-800 p-6 rounded-2xl shadow-sm border border-slate-100 dark:border-slate-700 transition-all hover:shadow-md">
        <p class="text-sm font-medium text-slate-500 dark:text-slate-400 uppercase tracking-wider mb-2">Total Accounts</p>
        <h3 class="text-3xl font-bold text-slate-800 dark:text-slate-100"><%= stats.totalAccounts %></h3>
    </div>
</div>

<!-- Prop Firm Summary Card -->
<div class="bg-white dark:bg-slate-800 p-6 md:p-8 rounded-2xl shadow-sm border border-slate-100 dark:border-slate-700 mb-8 overflow-hidden relative">
    <div class="grid grid-cols-1 lg:grid-cols-3 gap-8 items-center">
        <div class="lg:col-span-2">
            <h2 class="text-xl font-bold text-slate-800 dark:text-slate-100 mb-8 flex items-center gap-2">
                <span class="p-2 bg-blue-50 dark:bg-blue-900/30 rounded-lg text-blue-600">🏢</span> 
                Performance Summary
            </h2>
            <div class="grid grid-cols-1 sm:grid-cols-3 gap-6 md:gap-8">
                <div class="space-y-1">
                    <p class="text-[10px] font-bold text-slate-400 uppercase tracking-widest leading-tight">Total Payout</p>
                    <h3 class="text-2xl font-bold text-emerald-500 tracking-tight">$<%= Number(stats.totalPayout).toLocaleString() %></h3>
                </div>
                <div class="space-y-1">
                    <p class="text-[10px] font-bold text-slate-400 uppercase tracking-widest leading-tight">Total Spending</p>
                    <h3 class="text-2xl font-bold text-rose-500 tracking-tight">$<%= Number(stats.totalSpending).toLocaleString() %></h3>
                </div>
                <div class="space-y-1">
                    <p class="text-[10px] font-bold text-slate-400 uppercase tracking-widest leading-tight">Overall ROI</p>
                    <h3 class="text-2xl font-bold tracking-tight <%= stats.totalROI >= 0 ? 'text-emerald-500' : 'text-rose-500' %>">
                        <%= stats.totalROI %>%
                    </h3>
                </div>
            </div>
        </div>
        <div class="flex justify-center lg:justify-end">
            <div class="relative w-full max-w-[200px] aspect-square">
                <canvas id="financialDonutChart"></canvas>
            </div>
        </div>
    </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
<script>
    document.addEventListener('DOMContentLoaded', function() {
        const ctx = document.getElementById('financialDonutChart').getContext('2d');
        const isDark = document.documentElement.classList.contains('dark');
        
        new Chart(ctx, {
            type: 'doughnut',
            data: {
                labels: ['Payouts', 'Spending'],
                datasets: [{
                    data: [<%= stats.totalPayout %>, <%= stats.totalSpending %>],
                    backgroundColor: ['#10b981', '#ef4444'],
                    borderWidth: 0,
                    hoverOffset: 10
                }]
            },
            options: {
                responsive: true,
                maintainAspectRatio: false,
                plugins: {
                    legend: {
                        position: 'bottom',
                        labels: {
                            usePointStyle: true,
                            padding: 25,
                            color: isDark ? '#94a3b8' : '#64748b',
                            font: { family: 'Poppins', size: 11, weight: '500' }
                        }
                    }
                },
                cutout: '75%'
            }
        });
    });
</script>

<!-- ROI Breakdown Table -->
<div class="bg-white dark:bg-slate-800 rounded-2xl shadow-sm border border-slate-100 dark:border-slate-700 mb-8 overflow-hidden">
    <div class="px-6 py-5 border-b border-slate-100 dark:border-slate-700 flex justify-between items-center bg-slate-50/50 dark:bg-slate-800/50">
        <h2 class="text-lg font-bold text-slate-800 dark:text-slate-100">Prop Firm ROI Breakdown</h2>
        <span class="text-xs font-medium text-slate-400 bg-slate-100 dark:bg-slate-700 px-2 py-1 rounded">Latest Accounts</span>
    </div>
    <div class="overflow-x-auto">
        <table class="w-full text-left">
            <thead>
                <tr class="bg-slate-50 dark:bg-slate-900/50 border-b border-slate-100 dark:border-slate-700">
                    <th class="px-6 py-4 text-xs font-bold text-slate-500 dark:text-slate-400 uppercase tracking-wider">Prop Firm / ID</th>
                    <th class="px-6 py-4 text-xs font-bold text-slate-500 dark:text-slate-400 uppercase tracking-wider">Account Size</th>
                    <th class="px-6 py-4 text-xs font-bold text-slate-500 dark:text-slate-400 uppercase tracking-wider">Investment</th>
                    <th class="px-6 py-4 text-xs font-bold text-slate-500 dark:text-slate-400 uppercase tracking-wider">Total Payout</th>
                    <th class="px-6 py-4 text-xs font-bold text-slate-500 dark:text-slate-400 uppercase tracking-wider">ROI (%)</th>
                </tr>
            </thead>
            <tbody class="divide-y divide-slate-100 dark:divide-slate-700">
                <% recentAccounts.forEach(acc => { %>
                <tr class="hover:bg-slate-50 dark:hover:bg-slate-700/50 transition-colors">
                    <td class="px-6 py-4">
                        <div class="font-bold text-slate-800 dark:text-slate-100"><%= acc.propfirm_name %></div>
                        <% if (acc.account_login_id) { %>
                            <div class="text-xs text-slate-400 font-medium tracking-tight mt-0.5">ID: #<%= acc.account_login_id %></div>
                        <% } %>
                    </td>
                    <td class="px-6 py-4 font-semibold text-slate-700 dark:text-slate-300">$<%= Number(acc.account_size).toLocaleString() %></td>
                    <td class="px-6 py-4 text-rose-500/80 font-medium">$<%= Number(acc.initial_cost || 0).toLocaleString() %></td>
                    <td class="px-6 py-4 text-emerald-500 font-bold">$<%= Number(acc.total_payout).toLocaleString() %></td>
                    <td class="px-6 py-4">
                        <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-bold <%= acc.roi >= 0 ? 'bg-emerald-100 text-emerald-700 dark:bg-emerald-900/30 dark:text-emerald-400' : 'bg-rose-100 text-rose-700 dark:bg-rose-900/30 dark:text-rose-400' %>">
                            <%= acc.roi ? Number(acc.roi).toFixed(2) : '0.00' %>%
                        </span>
                    </td>
                </tr>
                <% }) %>
            </tbody>
        </table>
    </div>
</div>

<div class="grid grid-cols-1 lg:grid-cols-2 gap-8">
    <!-- Account History -->
    <div class="bg-white dark:bg-slate-800 rounded-2xl shadow-sm border border-slate-100 dark:border-slate-700 overflow-hidden">
        <div class="px-6 py-5 border-b border-slate-100 dark:border-slate-700 flex justify-between items-center">
            <h2 class="text-lg font-bold text-slate-800 dark:text-slate-100">Latest Accounts</h2>
            <a href="/accounts" class="text-sm font-bold text-blue-600 hover:text-blue-700 transition-colors">View All &rarr;</a>
        </div>
        <div class="divide-y divide-slate-100 dark:divide-slate-700">
            <% recentAccounts.slice(0, 5).forEach(acc => { %>
            <div class="px-6 py-4 flex items-center justify-between hover:bg-slate-50 dark:hover:bg-slate-700/50 transition-colors">
                <div>
                    <p class="font-bold text-slate-800 dark:text-slate-100"><%= acc.propfirm_name %> <span class="text-slate-400 font-normal ml-1">#<%= acc.account_login_id %></span></p>
                    <p class="text-xs text-slate-400 mt-0.5">$<%= Number(acc.account_size).toLocaleString() %></p>
                </div>
                <span class="px-2 py-1 rounded text-[10px] font-bold uppercase tracking-wider <%= acc.status === 'active' ? 'bg-emerald-100 text-emerald-700 dark:bg-emerald-900/30 dark:text-emerald-400' : 'bg-rose-100 text-rose-700 dark:bg-rose-900/30 dark:text-rose-400' %>">
                    <%= acc.status %>
                </span>
            </div>
            <% }) %>
        </div>
    </div>

    <!-- Payout History -->
    <div class="bg-white dark:bg-slate-800 rounded-2xl shadow-sm border border-slate-100 dark:border-slate-700 overflow-hidden">
        <div class="px-6 py-5 border-b border-slate-100 dark:border-slate-700 flex justify-between items-center">
            <h2 class="text-lg font-bold text-slate-800 dark:text-slate-100">Recent Payouts</h2>
            <a href="/payouts" class="text-sm font-bold text-blue-600 hover:text-blue-700 transition-colors">View All &rarr;</a>
        </div>
        <div class="divide-y divide-slate-100 dark:divide-slate-700">
            <% recentPayouts.slice(0, 5).forEach(p => { %>
            <div class="px-6 py-4 flex items-center justify-between hover:bg-slate-50 dark:hover:bg-slate-700/50 transition-colors">
                <div>
                    <p class="font-bold text-slate-800 dark:text-slate-100"><%= p.account_name %></p>
                    <p class="text-[10px] text-slate-400 uppercase font-bold mt-0.5">Profit at Payout: $<%= Number(p.account_balance).toLocaleString() %></p>
                </div>
                <div class="text-right">
                    <p class="text-emerald-500 font-bold">$<%= Number(p.amount).toLocaleString() %></p>
                    <span class="text-[10px] font-bold text-slate-400 uppercase tracking-tighter"><%= p.status %></span>
                </div>
            </div>
            <% }) %>
            <% if (recentPayouts.length === 0) { %>
                <div class="p-8 text-center text-slate-400 text-sm">No recent payouts recorded.</div>
            <% } %>
        </div>
    </div>
</div>
