                    <div class="w-10 h-10 bg-slate-50 dark:bg-slate-800 border border-slate-100 dark:border-slate-700 rounded-xl flex items-center justify-center">
                        <i data-lucide="arrow-down-left" class="w-5 h-5 text-emerald-500 group-hover:scale-110 transition-transform"></i>
                    </div>
                    <div>
                        <p class="font-bold text-slate-800 dark:text-slate-100 truncate max-w-[150px]"><%= p.account_name %></p>
                        <p class="text-[9px] text-slate-400 uppercase font-black mt-0.5 tracking-tighter">Approved <%= new Date(p.request_date).toLocaleDateString() %></p>
                    </div>
                </div>
                <div class="text-right">
                    <p class="text-emerald-500 font-black text-lg">$<%= Number(p.amount).toLocaleString() %></p>
                    <span class="text-[9px] font-bold text-slate-400 uppercase tracking-tighter border border-slate-100 dark:border-slate-700 px-1.5 py-0.5 rounded-md"><%= p.status %></span>
                </div>
            </div>
            <% }) %>
            <% if (recentPayouts.length === 0) { %>
                <div class="p-12 text-center">
                    <div class="w-12 h-12 bg-slate-50 dark:bg-slate-900 rounded-full flex items-center justify-center mx-auto mb-3">
                        <i data-lucide="coffee" class="w-6 h-6 text-slate-300"></i>
                    </div>
                    <p class="text-slate-400 text-sm italic">Passive income pending...</p>
                </div>
            <% } %>
        </div>
    </div>

    <!-- Smart Alerts / Insights -->
    <div class="bg-white dark:bg-slate-800 rounded-2xl shadow-sm border border-slate-100 dark:border-slate-700 flex flex-col">
        <div class="px-6 py-5 border-b border-slate-100 dark:border-slate-700 bg-slate-50/30 dark:bg-slate-800/50">
            <h2 class="text-lg font-bold text-slate-800 dark:text-slate-100 flex items-center gap-2">
                <i data-lucide="zap" class="w-5 h-5 text-amber-500"></i> Portfolio Alerts
            </h2>
        </div>
        <div class="p-8 space-y-6 flex-grow">
            <div class="flex gap-5 p-5 bg-emerald-50/50 dark:bg-emerald-900/10 rounded-2xl border border-emerald-100/50 dark:border-emerald-800/30 group hover:border-emerald-200 transition-colors">
                <div class="w-12 h-12 bg-emerald-500 rounded-2xl flex items-center justify-center shrink-0 shadow-lg shadow-emerald-500/20 group-hover:scale-105 transition-transform">
                    <i data-lucide="check-circle" class="w-6 h-6 text-white"></i>
                </div>
                <div>
                    <h4 class="font-bold text-emerald-800 dark:text-emerald-400 text-base">Capital Recovered</h4>
                    <p class="text-xs text-emerald-700/80 dark:text-emerald-500/70 mt-1.5 leading-relaxed font-medium">Your total payouts have exceeded your initial purchase costs. You are successfully playing with <strong class="text-emerald-600">House Money</strong>.</p>
                </div>
            </div>

            <div class="flex gap-5 p-5 bg-blue-50/50 dark:bg-blue-900/10 rounded-2xl border border-blue-100/50 dark:border-blue-800/30 group hover:border-blue-200 transition-colors">
                <div class="w-12 h-12 bg-blue-500 rounded-2xl flex items-center justify-center shrink-0 shadow-lg shadow-blue-500/20 group-hover:scale-105 transition-transform">
                    <i data-lucide="info" class="w-6 h-6 text-white"></i>
                </div>
                <div>
                    <h4 class="font-bold text-blue-800 dark:text-blue-400 text-base">Performance Tip</h4>
                    <p class="text-xs text-blue-700/80 dark:text-blue-500/70 mt-1.5 leading-relaxed font-medium">Data shows early week trading (Mon-Tue) yields the lowest drawdown. Consider sizing down on Fridays.</p>
                </div>
            </div>
        </div>
    </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
<script>
    document.addEventListener('DOMContentLoaded', function() {
        const isDark = document.documentElement.classList.contains('dark');
        const gridColor = isDark ? 'rgba(148, 163, 184, 0.1)' : 'rgba(100, 116, 139, 0.1)';
        const textColor = isDark ? '#94a3b8' : '#64748b';

        // Prop Firm ROI Curve Chart
        const equityCtx = document.getElementById('equityCurveChart').getContext('2d');
        const payoutGradient = equityCtx.createLinearGradient(0, 0, 0, 400);
        payoutGradient.addColorStop(0, 'rgba(37, 99, 235, 0.1)');
        payoutGradient.addColorStop(1, 'rgba(37, 99, 235, 0)');

        const spendingGradient = equityCtx.createLinearGradient(0, 0, 0, 400);
        spendingGradient.addColorStop(0, 'rgba(244, 63, 94, 0.1)');
        spendingGradient.addColorStop(1, 'rgba(244, 63, 94, 0)');

        const chartMonths = [<% chartData.forEach(d => { %>'<%= d.month %>',<% }) %>];
        const payoutData = [<% chartData.forEach(d => { %><%= d.payout %>,<% }) %>];
        const spendingData = [<% chartData.forEach(d => { %><%= d.spending %>,<% }) %>];

        new Chart(equityCtx, {
            type: 'line',
            data: {
                labels: chartMonths.length > 0 ? chartMonths : ['No Data'],
                datasets: [
                    {
                        label: 'Cumulative Payouts',
                        data: payoutData.length > 0 ? payoutData : [0],
                        borderColor: '#2563eb',
                        backgroundColor: payoutGradient,
                        borderWidth: 3,
                        fill: true,
                        tension: 0.4,
                        pointRadius: 4,
                        pointBackgroundColor: '#2563eb',
                        pointBorderColor: isDark ? '#1e293b' : '#fff',
                        pointBorderWidth: 2
                    },
                    {
                        label: 'Cumulative Spending',
                        data: spendingData.length > 0 ? spendingData : [0],
                        borderColor: '#f43f5e',
                        backgroundColor: spendingGradient,
                        borderWidth: 2,
                        fill: true,
                        tension: 0.4,
                        pointRadius: 0, // Less prominent for spending
                        borderDash: [5, 5] // Dashed line for spending
                    }
                ]
            },
            options: {
                responsive: true,
                maintainAspectRatio: false,
                plugins: {
                    legend: { display: false },
                    tooltip: {
                        mode: 'index',
                        intersect: false,
                        callbacks: {
                            label: (context) => {
                                return ` ${context.dataset.label}: $${context.raw.toLocaleString()}`;
                            }
                        }
                    }
                },
                scales: {
                    y: {
                        grid: { color: gridColor },
                        ticks: { 
                            color: textColor,
                            font: { family: 'Poppins', size: 10 },
                            callback: value => '$' + value.toLocaleString()
                        }
                    },
                    x: {
                        grid: { display: false },
                        ticks: { color: textColor, font: { family: 'Poppins', size: 10 } }
                    }
                }
            }
        });
        
        // Refresh icons
        if (typeof lucide !== 'undefined') {
            lucide.createIcons();
        }
    });
</script>

