        <div class="px-6 py-5 border-b border-slate-100 dark:border-slate-700 flex justify-between items-center bg-slate-50/30 dark:bg-slate-800/50">
            <h2 class="text-lg font-bold text-slate-800 dark:text-slate-100 flex items-center gap-2">
                <i data-lucide="receipt" class="w-5 h-5 text-emerald-500"></i> Revenue Stream
            </h2>
            <a href="/payouts" class="text-[10px] font-bold text-blue-600 hover:text-blue-700 transition-colors uppercase tracking-widest bg-blue-50 dark:bg-blue-900/30 px-3 py-1 rounded-full">Explore History &rarr;</a>
        </div>
        <div class="divide-y divide-slate-100 dark:divide-slate-700 flex-grow">
