<div class="card" style="max-width: 600px; margin: 0 auto;">
    <h2 class="card-title">Edit Prop Account</h2>
    <form action="/accounts/<%= account.id %>?_method=PUT" method="POST">
        <div class="form-group">
            <label>Account Name</label>
            <input type="text" name="account_name" class="form-control" value="<%= account.account_name %>" required>
        </div>
        <div class="form-group">
            <label>Prop Firm Name</label>
            <input type="text" name="propfirm_name" class="form-control" value="<%= account.propfirm_name %>" required>
        </div>
        <div class="form-group">
            <label>Account Type</label>
            <select name="account_type" class="form-control">
                <option value="instan" <%= account.account_type === 'instan' ? 'selected' : '' %>>Instan</option>
                <option value="1 step" <%= account.account_type === '1 step' ? 'selected' : '' %>>1 Step</option>
                <option value="2 step" <%= account.account_type === '2 step' ? 'selected' : '' %>>2 Step</option>
                <option value="mini" <%= account.account_type === 'mini' ? 'selected' : '' %>>Mini</option>
            </select>
        </div>
        <div class="form-group">
            <label>Current Balance ($)</label>
            <input type="number" step="0.01" name="balance" class="form-control" value="<%= account.balance %>" required>
        </div>
        <div class="form-group">
            <label>Investment (Purchase Price $)</label>
            <input type="number" step="0.01" name="initial_cost" class="form-control" value="<%= account.initial_cost %>" required>
        </div>
        <div class="form-group">
            <label>Status</label>
            <select name="status" class="form-control">
                <option value="challenge" <%= account.status === 'challenge' ? 'selected' : '' %>>Challenge</option>
                <option value="active" <%= account.status === 'active' ? 'selected' : '' %>>Active</option>
                <option value="funded" <%= account.status === 'funded' ? 'selected' : '' %>>Funded</option>
                <option value="breached" <%= account.status === 'breached' ? 'selected' : '' %>>Breached</option>
            </select>
        </div>
        <div class="form-group">
            <label>Total Payout to Date ($)</label>
            <input type="number" step="0.01" name="total_payout" class="form-control" value="<%= account.total_payout %>">
        </div>

        <div style="margin-top: 1.5rem;">
            <button type="submit" class="btn btn-primary">Update Account</button>
            <a href="/accounts" class="btn btn-secondary" style="background: #e2e8f0; color: #475569;">Cancel</a>
        </div>
    </form>
</div>
