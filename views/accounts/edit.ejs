<div class="max-w-2xl mx-auto">
    <div class="bg-white dark:bg-slate-800 rounded-3xl shadow-xl border border-slate-100 dark:border-slate-700 overflow-hidden">
        <div class="px-8 py-6 border-b border-slate-100 dark:border-slate-700 bg-slate-50/50 dark:bg-slate-800/50">
            <h2 class="text-xl font-bold text-slate-800 dark:text-slate-100">Edit Prop Account</h2>
            <p class="text-xs text-slate-400 mt-1 font-medium italic">Modify the credentials and details for your existing prop firm account.</p>
        </div>

        <form action="/accounts/<%= account.id %>?_method=PUT" method="POST" class="p-5 md:p-8">
            <div class="grid grid-cols-1 md:grid-cols-2 gap-6">

                <!-- Prop Firm -->
                <div>
                    <label class="block text-xs font-bold text-slate-400 uppercase tracking-widest mb-2">Prop Firm</label>
                    <select name="prop_firm_id" required
                            class="w-full px-4 py-3 rounded-xl border border-slate-200 dark:border-slate-700 bg-slate-50 dark:bg-slate-900 text-slate-800 dark:text-slate-100 focus:outline-none focus:ring-2 focus:ring-blue-500/20 focus:border-blue-500 transition-all appearance-none cursor-pointer">
                        <% firms.forEach(firm => { %>
                            <option value="<%= firm.id %>" <%= account.prop_firm_id == firm.id ? 'selected' : '' %> class="bg-white dark:bg-slate-800 text-slate-800 dark:text-slate-100"><%= firm.name %></option>
                        <% }) %>
                    </select>
                </div>

                <!-- Account ID -->
                <div>
                    <label class="block text-xs font-bold text-slate-400 uppercase tracking-widest mb-2">Account ID (Login)</label>
                    <input type="text" name="account_login_id" value="<%= account.account_login_id %>"
                           class="w-full px-4 py-3 rounded-xl border border-slate-200 dark:border-slate-700 bg-slate-50 dark:bg-slate-900 text-slate-800 dark:text-slate-100 focus:outline-none focus:ring-2 focus:ring-blue-500/20 focus:border-blue-500 transition-all"
                           placeholder="e.g. 12345678">
                </div>

                <!-- Account Type -->
                <div>
                    <label class="block text-xs font-bold text-slate-400 uppercase tracking-widest mb-2">Account Type</label>
                    <select name="account_type"
                            class="w-full px-4 py-3 rounded-xl border border-slate-200 dark:border-slate-700 bg-slate-50 dark:bg-slate-900 text-slate-800 dark:text-slate-100 focus:outline-none focus:ring-2 focus:ring-blue-500/20 focus:border-blue-500 transition-all appearance-none cursor-pointer">
                        <option value="instan" <%= account.account_type === 'instan' ? 'selected' : '' %> class="bg-white dark:bg-slate-800 text-slate-800 dark:text-slate-100">Instan</option>
                        <option value="1 step" <%= account.account_type === '1 step' ? 'selected' : '' %> class="bg-white dark:bg-slate-800 text-slate-800 dark:text-slate-100">1 Step</option>
                        <option value="2 step" <%= account.account_type === '2 step' ? 'selected' : '' %> class="bg-white dark:bg-slate-800 text-slate-800 dark:text-slate-100">2 Step</option>
                        <option value="mini" <%= account.account_type === 'mini' ? 'selected' : '' %> class="bg-white dark:bg-slate-800 text-slate-800 dark:text-slate-100">Mini</option>
                    </select>
                </div>

                <!-- Initial Balance -->
                <div>
                    <label class="block text-xs font-bold text-slate-400 uppercase tracking-widest mb-2">Balance ($)</label>
                    <div class="relative">
                        <div class="absolute inset-y-0 left-0 pl-4 flex items-center pointer-events-none">
                            <span class="text-slate-400 text-sm">$</span>
                        </div>
                        <input type="number" step="0.01" name="balance" value="<%= account.balance %>" required
                               class="w-full pl-8 pr-4 py-3 rounded-xl border border-slate-200 dark:border-slate-700 bg-slate-50 dark:bg-slate-900 text-slate-800 dark:text-slate-100 focus:outline-none focus:ring-2 focus:ring-blue-500/20 focus:border-blue-500 transition-all">
                    </div>
                </div>


                <!-- Investment -->
                <div>
                    <label class="block text-xs font-bold text-slate-400 uppercase tracking-widest mb-2">Purchase Cost ($)</label>
                    <div class="relative">
                        <div class="absolute inset-y-0 left-0 pl-4 flex items-center pointer-events-none">
                            <span class="text-slate-400 text-sm">$</span>
                        </div>
                        <input type="number" step="0.01" name="initial_cost" value="<%= account.initial_cost %>" required
                               class="w-full pl-8 pr-4 py-3 rounded-xl border border-slate-200 dark:border-slate-700 bg-slate-50 dark:bg-slate-900 text-slate-800 dark:text-slate-100 focus:outline-none focus:ring-2 focus:ring-blue-500/20 focus:border-blue-500 transition-all">
                    </div>
                </div>

                <!-- Status -->
                <div>
                    <label class="block text-xs font-bold text-slate-400 uppercase tracking-widest mb-2">Status</label>
                    <select name="status"
                            class="w-full px-4 py-3 rounded-xl border border-slate-200 dark:border-slate-700 bg-slate-50 dark:bg-slate-900 text-slate-800 dark:text-slate-100 focus:outline-none focus:ring-2 focus:ring-blue-500/20 focus:border-blue-500 transition-all appearance-none cursor-pointer">
                        <option value="active" <%= account.status === 'active' ? 'selected' : '' %> class="bg-white dark:bg-slate-800 text-slate-800 dark:text-slate-100">Active</option>
                        <option value="passed" <%= account.status === 'passed' ? 'selected' : '' %> class="bg-white dark:bg-slate-800 text-slate-800 dark:text-slate-100">Passed</option>
                        <option value="funded" <%= account.status === 'funded' ? 'selected' : '' %> class="bg-white dark:bg-slate-800 text-slate-800 dark:text-slate-100">Funded</option>
                        <option value="breached" <%= account.status === 'breached' ? 'selected' : '' %> class="bg-white dark:bg-slate-800 text-slate-800 dark:text-slate-100">Breached</option>
                    </select>
                </div>

                <!-- Total Payout -->
                <div class="md:col-span-2">
                    <label class="block text-xs font-bold text-slate-400 uppercase tracking-widest mb-2">Total Payouts to Date ($)</label>
                    <div class="relative">
                        <div class="absolute inset-y-0 left-0 pl-4 flex items-center pointer-events-none">
                            <span class="text-slate-400 text-sm">$</span>
                        </div>
                        <input type="number" step="0.01" name="total_payout" value="<%= account.total_payout %>"
                               class="w-full pl-8 pr-4 py-3 rounded-xl border border-slate-200 dark:border-slate-700 bg-slate-50 dark:bg-slate-900 text-slate-800 dark:text-slate-100 focus:outline-none focus:ring-2 focus:ring-blue-500/20 focus:border-blue-500 transition-all font-bold text-emerald-500">
                    </div>
                </div>
            </div>

            <div class="mt-10 flex gap-4">
                <button type="submit" class="flex-1 bg-blue-600 hover:bg-blue-700 text-white font-bold py-3 px-6 rounded-2xl transition-all shadow-lg shadow-blue-500/25">
                    Update Account
                </button>
                <a href="/accounts" class="px-8 py-3 rounded-2xl bg-slate-100 dark:bg-slate-700 hover:bg-slate-200 dark:hover:bg-slate-600 text-slate-600 dark:text-slate-300 font-bold transition-all">
                    Cancel
                </a>
            </div>
        </form>
    </div>
</div>
