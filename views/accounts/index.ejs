<div class="page-header">
    <div style="display: flex; justify-content: space-between; align-items: center;">
        <div>
            <h1 class="page-title">Prop Firm Accounts</h1>
            <p class="page-subtitle">Manage and track your evaluation and funded stages.</p>
        </div>
        <a href="/accounts/add" class="btn btn-primary">
            <i data-lucide="plus" style="width: 16px;"></i>
            Add New Account
        </a>
    </div>
</div>

<div class="card-table-wrapper">
    <div class="card-header">
        <h3 class="card-title">All Trading Accounts</h3>
    </div>
    <table>
        <thead>
            <tr>
                <th>Trading Info</th>
                <th>Type</th>
                <th>Size / Balance</th>
                <th>Status</th>
                <th style="text-align: right;">Total Payout</th>
                <th style="text-align: right;">Actions</th>
            </tr>
        </thead>
        <tbody>
            <% accounts.forEach(acc => { %>
            <tr>
                <td>
                    <div style="font-weight: 600;"><%= acc.propfirm_name %></div>
                    <div style="font-size: 0.75rem; color: var(--text-muted);">#<%= acc.account_login_id || 'N/A' %></div>
                </td>
                <td>
                    <span class="badge badge-info"><%= acc.account_type %></span>
                </td>
                <td>
                    <div style="font-weight: 600;">$<%= Number(acc.balance).toLocaleString() %></div>
                    <div style="font-size: 0.7rem; color: var(--text-muted);">Equity Value</div>
                </td>
                <td>
                    <span class="badge badge-<%= acc.status === 'active' || acc.status === 'funded' ? 'success' : (acc.status === 'passed' ? 'info' : 'danger') %>">
                        <%= acc.status %>
                    </span>
                </td>
                <td style="text-align: right; font-weight: 700; color: var(--accent);">
                    $<%= Number(acc.total_payout).toLocaleString() %>
                </td>
                <td style="text-align: right;">
                    <div style="display: flex; justify-content: flex-end; gap: 0.5rem;">
                        <a href="/accounts/<%= acc.id %>/edit" class="btn btn-ghost" style="padding: 0.4rem;"><i data-lucide="edit-3" style="width: 16px;"></i></a>
                        <form action="/accounts/<%= acc.id %>?_method=DELETE" method="POST" onsubmit="return confirm('Delete this account?')">
                            <button type="submit" class="btn btn-ghost" style="padding: 0.4rem; color: var(--danger);"><i data-lucide="trash-2" style="width: 16px;"></i></button>
                        </form>
                    </div>
                </td>
            </tr>
            <% }) %>
        </tbody>
    </table>
    <% if (accounts.length === 0) { %>
        <div style="padding: 3rem; text-align: center; color: var(--text-muted); font-style: italic;">
            No accounts found. Add your first prop firm account to get started.
        </div>
    <% } %>
</div>
