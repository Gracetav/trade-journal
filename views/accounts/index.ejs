<div class="bg-white dark:bg-slate-800 rounded-2xl shadow-sm border border-slate-100 dark:border-slate-700 overflow-hidden">
    <div class="px-6 py-5 border-b border-slate-100 dark:border-slate-700 flex justify-between items-center bg-slate-50/50 dark:bg-slate-800/50">
        <h2 class="text-lg font-bold text-slate-800 dark:text-slate-100">Prop Firm Accounts</h2>
        <a href="/accounts/add" class="bg-blue-600 hover:bg-blue-700 text-white font-bold py-2 px-6 rounded-xl transition-all shadow-lg shadow-blue-500/20 text-sm">
            + Add New Account
        </a>
    </div>

    <!-- Desktop Table View -->
    <div class="hidden md:block overflow-x-auto">
        <table class="w-full text-left border-collapse">
            <thead>
                <tr class="bg-slate-50 dark:bg-slate-900/50 border-b border-slate-100 dark:border-slate-700">
                    <th class="px-6 py-4 text-xs font-bold text-slate-500 dark:text-slate-400 uppercase tracking-wider">Trading Info</th>
                    <th class="hidden xl:table-cell px-6 py-4 text-xs font-bold text-slate-500 dark:text-slate-400 uppercase tracking-wider text-center">Type</th>
                    <th class="hidden xl:table-cell px-6 py-4 text-xs font-bold text-slate-500 dark:text-slate-400 uppercase tracking-wider text-right">Size / Balance</th>
                    <th class="px-6 py-4 text-xs font-bold text-slate-500 dark:text-slate-400 uppercase tracking-wider text-center">Status</th>
                    <th class="px-6 py-4 text-xs font-bold text-slate-500 dark:text-slate-400 uppercase tracking-wider text-right">Total Payout</th>
                    <th class="px-6 py-4 text-xs font-bold text-slate-500 dark:text-slate-400 uppercase tracking-wider text-right">Actions</th>
                </tr>
            </thead>
            <tbody class="divide-y divide-slate-100 dark:divide-slate-700">
                <% accounts.forEach(acc => { %>
                <tr class="hover:bg-slate-50 dark:hover:bg-slate-700/50 transition-colors">
                    <td class="px-6 py-4">
                        <div class="font-bold text-slate-800 dark:text-slate-100"><%= acc.propfirm_name %></div>
                        <div class="flex flex-col text-[10px] text-slate-400 font-bold uppercase tracking-tight mt-0.5">
                            <span>ID: #<%= acc.account_login_id || 'N/A' %></span>
                        </div>
                    </td>
                    <td class="hidden xl:table-cell px-6 py-4 text-center">
                        <span class="px-2 py-0.5 bg-slate-100 dark:bg-slate-700 border border-slate-200 dark:border-slate-600 rounded text-[10px] font-bold text-slate-500 dark:text-slate-400 uppercase"><%= acc.account_type %></span>
                    </td>
                    <td class="hidden xl:table-cell px-6 py-4 text-right">
                        <div class="font-bold text-slate-700 dark:text-slate-200 tracking-tight">$<%= Number(acc.balance).toLocaleString() %></div>
                    </td>
                    <td class="px-6 py-4 text-center">
                        <form action="/accounts/<%= acc.id %>/status?_method=PATCH" method="POST" class="status-form">
                            <select name="status" onchange="this.form.submit()" 
                                    class="appearance-none px-3 py-1.5 rounded-lg text-[10px] font-black uppercase tracking-widest text-center cursor-pointer border-2 transition-all focus:ring-4 focus:ring-blue-500/10
                                    <%= acc.status === 'active' ? 'bg-emerald-50 text-emerald-600 border-emerald-100 dark:bg-emerald-900/20 dark:text-emerald-400 dark:border-emerald-800/30' : 
                                        acc.status === 'breached' ? 'bg-rose-50 text-rose-600 border-rose-100 dark:bg-rose-900/20 dark:text-rose-400 dark:border-rose-800/30' :
                                        acc.status === 'passed' ? 'bg-blue-50 text-blue-600 border-blue-100 dark:bg-blue-900/20 dark:text-blue-400 dark:border-blue-800/30' :
                                        'bg-purple-50 text-purple-600 border-purple-100 dark:bg-purple-900/20 dark:text-purple-400 dark:border-purple-800/30' %>">
                                <option value="active" <%= acc.status === 'active' ? 'selected' : '' %> class="bg-white dark:bg-slate-800 text-slate-800 dark:text-slate-100">Active</option>
                                <option value="passed" <%= acc.status === 'passed' ? 'selected' : '' %> class="bg-white dark:bg-slate-800 text-slate-800 dark:text-slate-100">Passed</option>
                                <option value="funded" <%= acc.status === 'funded' ? 'selected' : '' %> class="bg-white dark:bg-slate-800 text-slate-800 dark:text-slate-100">Funded</option>
                                <option value="breached" <%= acc.status === 'breached' ? 'selected' : '' %> class="bg-white dark:bg-slate-800 text-slate-800 dark:text-slate-100">Breached</option>
                            </select>
                        </form>
                    </td>
                    <td class="px-6 py-4 text-right font-bold text-emerald-500">$<%= Number(acc.total_payout).toLocaleString() %></td>
                    <td class="px-6 py-4 text-right">
                        <div class="flex justify-end gap-2">
                            <a href="/accounts/<%= acc.id %>/edit" 
                               class="w-9 h-9 flex items-center justify-center rounded-xl bg-slate-50 dark:bg-slate-700 border border-slate-100 dark:border-slate-600 text-slate-400 hover:text-blue-600 hover:bg-blue-50 dark:hover:bg-blue-900/30 transition-all shadow-sm">
                                <i data-lucide="edit-3" class="w-4 h-4"></i>
                            </a>
                            <form action="/accounts/<%= acc.id %>?_method=DELETE" method="POST" class="delete-form">
                                <button type="submit" 
                                        class="w-9 h-9 flex items-center justify-center rounded-xl bg-slate-50 dark:bg-slate-700 border border-slate-100 dark:border-slate-600 text-slate-400 hover:text-rose-600 hover:bg-rose-50 dark:hover:bg-rose-900/30 transition-all shadow-sm">
                                    <i data-lucide="trash-2" class="w-4 h-4"></i>
                                </button>
                            </form>
                        </div>
                    </td>
                </tr>
                <% }) %>
            </tbody>
        </table>
    </div>

    <!-- Mobile Card View -->
    <div class="md:hidden divide-y divide-slate-100 dark:divide-slate-700">
        <% accounts.forEach(acc => { %>
        <div class="p-5 space-y-4">
            <div class="flex justify-between items-start">
                <div>
                    <div class="font-black text-slate-800 dark:text-slate-100 text-base leading-tight"><%= acc.propfirm_name %></div>
                    <div class="text-[10px] text-slate-400 font-bold uppercase tracking-widest mt-1">ID: #<%= acc.account_login_id || 'N/A' %></div>
                    <span class="inline-block mt-2 px-2 py-0.5 bg-slate-100 dark:bg-slate-900 border border-slate-200 dark:border-slate-800 rounded text-[9px] font-black text-slate-500 uppercase tracking-tighter"><%= acc.account_type %></span>
                </div>
                <div class="shrink-0">
                    <form action="/accounts/<%= acc.id %>/status?_method=PATCH" method="POST" class="status-form">
                        <select name="status" onchange="this.form.submit()" 
                                class="appearance-none px-3 py-1.5 rounded-xl text-[10px] font-black uppercase tracking-widest text-center cursor-pointer border-2 transition-all shadow-sm
                                <%= acc.status === 'active' ? 'bg-emerald-50 text-emerald-600 border-emerald-100 dark:bg-emerald-900/20 dark:text-emerald-400 dark:border-emerald-800/30' : 
                                    acc.status === 'breached' ? 'bg-rose-50 text-rose-600 border-rose-100 dark:bg-rose-900/20 dark:text-rose-400 dark:border-rose-800/30' :
                                    acc.status === 'passed' ? 'bg-blue-50 text-blue-600 border-blue-100 dark:bg-blue-900/20 dark:text-blue-400 dark:border-blue-800/30' :
                                    'bg-purple-50 text-purple-600 border-purple-100 dark:bg-purple-900/20 dark:text-purple-400 dark:border-purple-800/30' %>">
                            <option value="active" <%= acc.status === 'active' ? 'selected' : '' %>>Active</option>
                            <option value="passed" <%= acc.status === 'passed' ? 'selected' : '' %>>Passed</option>
                            <option value="funded" <%= acc.status === 'funded' ? 'selected' : '' %>>Funded</option>
                            <option value="breached" <%= acc.status === 'breached' ? 'selected' : '' %>>Breached</option>
                        </select>
                    </form>
                </div>
            </div>

            <div class="grid grid-cols-2 gap-4 py-3 px-4 bg-slate-50 dark:bg-slate-900/50 rounded-2xl border border-slate-100 dark:border-slate-800">
                <div>
                    <div class="text-[9px] font-bold text-slate-400 uppercase tracking-tighter mb-0.5">Asset Value</div>
                    <div class="font-bold text-slate-700 dark:text-slate-200 text-sm">$<%= Number(acc.balance).toLocaleString() %></div>
                </div>
                <div class="text-right">
                    <div class="text-[9px] font-bold text-slate-400 uppercase tracking-tighter mb-0.5">Total Payout</div>
                    <div class="font-black text-emerald-500 text-sm leading-none mt-1">$<%= Number(acc.total_payout).toLocaleString() %></div>
                </div>
            </div>

            <div class="flex items-center justify-end gap-2">
                <a href="/accounts/<%= acc.id %>/edit" class="p-2.5 bg-blue-50 dark:bg-blue-900/30 text-blue-600 dark:text-blue-400 rounded-xl">
                    <i data-lucide="edit-3" class="w-4 h-4"></i>
                </a>
                <form action="/accounts/<%= acc.id %>?_method=DELETE" method="POST" class="delete-form">
                    <button type="submit" class="p-2.5 bg-rose-50 dark:bg-rose-900/30 text-rose-600 dark:text-rose-400 rounded-xl">
                        <i data-lucide="trash-2" class="w-4 h-4"></i>
                    </button>
                </form>
            </div>
        </div>
        <% }) %>
    </div>

    <% if (accounts.length === 0) { %>
        <div class="px-6 py-12 text-center text-slate-400 italic">No account records found.</div>
    <% } %>
</div>
