<div class="max-w-4xl mx-auto">
    <div class="bg-white dark:bg-slate-800 rounded-3xl shadow-xl border border-slate-100 dark:border-slate-700 overflow-hidden">
        <div class="px-8 py-6 border-b border-slate-100 dark:border-slate-700 bg-slate-50/50 dark:bg-slate-800/50 flex justify-between items-center">
            <div>
                <h2 class="text-xl font-bold text-slate-800 dark:text-slate-100">Bulk Log Purchases</h2>
                <p class="text-xs text-slate-400 mt-1 font-medium italic">Record multiple prop firm account purchases at once.</p>
            </div>
            <button type="button" onclick="addPurchaseRow()" 
                    class="bg-blue-50 dark:bg-blue-900/30 text-blue-600 dark:text-blue-400 font-bold py-2 px-4 rounded-xl hover:bg-blue-100 dark:hover:bg-blue-900/50 transition-all text-sm flex items-center gap-2">
                <span class="text-lg">+</span> Add Another Account
            </button>
        </div>

        <form action="/purchases" method="POST" class="p-4 md:p-8">
            <div id="purchase-container" class="space-y-8">
                <!-- Initial Row -->
                <div class="purchase-row relative p-6 rounded-2xl bg-slate-50/50 dark:bg-slate-900/30 border border-slate-100 dark:border-slate-800/50 transition-all">
                    <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
                        <!-- Prop Firm -->
                        <div class="md:col-span-1">
                            <label class="block text-[10px] font-black text-slate-400 uppercase tracking-widest mb-2">Prop Firm</label>
                            <select name="prop_firm_id[]" required
                                    class="w-full px-4 py-3 rounded-xl border border-slate-200 dark:border-slate-700 bg-white dark:bg-slate-900 text-slate-800 dark:text-slate-100 focus:outline-none focus:ring-2 focus:ring-blue-500/20 focus:border-blue-500 transition-all appearance-none cursor-pointer">
                                <option value="" class="bg-white dark:bg-slate-800 text-slate-800 dark:text-slate-100">-- Select Firm --</option>
                                <% firms.forEach(firm => { %>
                                    <option value="<%= firm.id %>" class="bg-white dark:bg-slate-800 text-slate-800 dark:text-slate-100"><%= firm.name %></option>
                                <% }) %>
                            </select>
                        </div>

                        <!-- Account ID -->
                        <div class="md:col-span-1">
                            <label class="block text-[10px] font-black text-slate-400 uppercase tracking-widest mb-2">Account ID (Login)</label>
                            <input type="text" name="account_login_id[]"
                                   class="w-full px-4 py-3 rounded-xl border border-slate-200 dark:border-slate-700 bg-white dark:bg-slate-900 text-slate-800 dark:text-slate-100 focus:outline-none focus:ring-2 focus:ring-blue-500/20 focus:border-blue-500 transition-all"
                                   placeholder="Optional ID">
                        </div>

                        <!-- Account Type -->
                        <div class="md:col-span-1">
                            <label class="block text-[10px] font-black text-slate-400 uppercase tracking-widest mb-2">Account Type</label>
                            <select name="account_type[]"
                                    class="w-full px-4 py-3 rounded-xl border border-slate-200 dark:border-slate-700 bg-white dark:bg-slate-900 text-slate-800 dark:text-slate-100 focus:outline-none focus:ring-2 focus:ring-blue-500/20 focus:border-blue-500 transition-all appearance-none cursor-pointer">
                                <option value="instan" class="bg-white dark:bg-slate-800 text-slate-800 dark:text-slate-100">Instan</option>
                                <option value="1 step" class="bg-white dark:bg-slate-800 text-slate-800 dark:text-slate-100">1 Step</option>
                                <option value="2 step" class="bg-white dark:bg-slate-800 text-slate-800 dark:text-slate-100" selected>2 Step</option>
                                <option value="mini" class="bg-white dark:bg-slate-800 text-slate-800 dark:text-slate-100">Mini</option>
                            </select>
                        </div>

                        <!-- Balance -->
                        <div>
                            <label class="block text-[10px] font-black text-slate-400 uppercase tracking-widest mb-2">Balance ($)</label>
                            <div class="relative">
                                <div class="absolute inset-y-0 left-0 pl-4 flex items-center pointer-events-none">
                                    <span class="text-slate-400 text-xs">$</span>
                                </div>
                                <input type="number" step="0.01" name="account_size[]" required
                                       class="w-full pl-8 pr-4 py-3 rounded-xl border border-slate-200 dark:border-slate-700 bg-white dark:bg-slate-900 text-slate-800 dark:text-slate-100 focus:outline-none focus:ring-2 focus:ring-blue-500/20 focus:border-blue-500 transition-all"
                                       placeholder="100000.00">
                            </div>
                        </div>

                        <!-- Price Paid -->
                        <div>
                            <label class="block text-[10px] font-black text-slate-400 uppercase tracking-widest mb-2">Price Paid ($)</label>
                            <div class="relative">
                                <div class="absolute inset-y-0 left-0 pl-4 flex items-center pointer-events-none">
                                    <span class="text-slate-400 text-xs">$</span>
                                </div>
                                <input type="number" step="0.01" name="price[]" required
                                       class="w-full pl-8 pr-4 py-3 rounded-xl border border-slate-200 dark:border-slate-700 bg-white dark:bg-slate-900 text-slate-800 dark:text-slate-100 focus:outline-none focus:ring-2 focus:ring-blue-500/20 focus:border-blue-500 transition-all font-bold text-rose-500"
                                       placeholder="0.00">
                            </div>
                        </div>

                        <!-- Purchase Date -->
                        <div>
                            <label class="block text-[10px] font-black text-slate-400 uppercase tracking-widest mb-2">Purchase Date</label>
                            <input type="date" name="purchase_date[]" required value="<%= moment().format('YYYY-MM-DD') %>"
                                   class="w-full px-4 py-3 rounded-xl border border-slate-200 dark:border-slate-700 bg-white dark:bg-slate-900 text-slate-800 dark:text-slate-100 focus:outline-none focus:ring-2 focus:ring-blue-500/20 focus:border-blue-500 transition-all cursor-pointer">
                        </div>
                    </div>
                </div>
            </div>

            <div class="mt-10 pt-8 border-t border-slate-100 dark:border-slate-700 flex gap-4">
                <button type="submit" class="flex-1 bg-blue-600 hover:bg-blue-700 text-white font-bold py-4 px-6 rounded-2xl transition-all shadow-lg shadow-blue-500/25">
                    Save All Purchases
                </button>
                <a href="/purchases" class="px-10 py-4 rounded-2xl bg-slate-100 dark:bg-slate-700 hover:bg-slate-200 dark:hover:bg-slate-600 text-slate-600 dark:text-slate-300 font-bold transition-all">
                    Cancel
                </a>
            </div>
        </form>
    </div>
</div>

<script>
    function addPurchaseRow() {
        const container = document.getElementById('purchase-container');
        const firstRow = container.querySelector('.purchase-row');
        const newRow = firstRow.cloneNode(true);
        
        // Clear inputs
        newRow.querySelectorAll('input').forEach(input => {
            if (input.type !== 'date') input.value = '';
        });
        newRow.querySelectorAll('select').forEach(select => {
            if (select.name.includes('account_type')) select.value = '2 step';
            else select.value = '';
        });

        // Add remove button
        const removeBtn = document.createElement('button');
        removeBtn.type = 'button';
        removeBtn.className = 'absolute -top-3 -right-3 w-8 h-8 rounded-full bg-rose-500 text-white flex items-center justify-center shadow-lg hover:bg-rose-600 transition-all';
        removeBtn.innerHTML = '×';
        removeBtn.onclick = function() {
            newRow.remove();
        };
        newRow.appendChild(removeBtn);

        container.appendChild(newRow);
    }
</script>
