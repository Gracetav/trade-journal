<div class="card" style="max-width: 600px; margin: 0 auto;">
    <h2 class="card-title">Add Account Purchase</h2>
    <form action="/purchases" method="POST">
        <div class="form-group">
            <label>Prop Firm Name</label>
            <input type="text" name="propfirm_name" class="form-control" placeholder="The Funded Trader, Blue Guardian, etc." required>
        </div>
        <div class="form-group">
            <label>Account Size ($)</label>
            <input type="number" step="0.01" name="account_size" class="form-control" placeholder="100000.00" required>
        </div>
        <div class="form-group">
            <label>Account Type</label>
            <select name="account_type" class="form-control">
                <option value="instan">Instan</option>
                <option value="1 step">1 Step</option>
                <option value="2 step" selected>2 Step</option>
                <option value="mini">Mini</option>
            </select>
        </div>
        <div class="form-group">
            <label>Price Paid ($)</label>
            <input type="number" step="0.01" name="price" class="form-control" placeholder="0.00" required>
        </div>
        <div class="form-group">
            <label>Purchase Date</label>
            <input type="date" name="purchase_date" class="form-control" required value="<%= moment().format('YYYY-MM-DD') %>">
        </div>

        <div style="margin-top: 1.5rem;">
            <button type="submit" class="btn btn-primary">Save Purchase</button>
            <a href="/purchases" class="btn btn-secondary" style="background: #e2e8f0; color: #475569;">Cancel</a>
        </div>
    </form>
</div>
