<div class="card">
    <div class="card-header">
        <h2 class="card-title">Account Purchases</h2>
        <a href="/purchases/add" class="btn btn-primary">Add Purchase</a>
    </div>

    <table>
        <thead>
            <tr>
                <th>Prop Firm</th>
                <th>Account Size</th>
                <th>Type</th>
                <th>Price Paid</th>
                <th>Date</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            <% purchases.forEach(p => { %>
            <tr>
                <td><strong><%= p.propfirm_name %></strong></td>
                <td>$<%= Number(p.account_size).toLocaleString() %></td>
                <td><span class="badge" style="background: #e2e8f0; color: #475569;"><%= p.account_type %></span></td>
                <td>$<%= Number(p.price).toLocaleString() %></td>
                <td><%= moment(p.purchase_date).format('MMM DD, YYYY') %></td>
                <td>
                    <div style="display: flex; gap: 5px;">
                        <a href="/purchases/<%= p.id %>/edit" class="btn btn-sm btn-primary">Edit</a>
                        <form action="/purchases/<%= p.id %>?_method=DELETE" method="POST" class="delete-form">
                            <button type="submit" class="btn btn-sm btn-danger">Delete</button>
                        </form>
                    </div>
                </td>
            </tr>
            <% }) %>
            <% if (purchases.length === 0) { %>
            <tr><td colspan="5" style="text-align: center;">No purchases found</td></tr>
            <% } %>
        </tbody>
    </table>
</div>
