<!-- ROI Stats Overview -->
<div class="grid grid-cols-1 sm:grid-cols-2 xl:grid-cols-4 gap-6 mb-8">
    <div class="bg-white dark:bg-slate-800 p-6 rounded-2xl shadow-sm border border-slate-100 dark:border-slate-700">
        <p class="text-xs font-bold text-slate-400 uppercase tracking-widest mb-1">Total Investment</p>
        <h3 class="text-2xl font-bold text-rose-500">$<%= Number(stats.totalInvestment).toLocaleString() %></h3>
    </div>
    <div class="bg-white dark:bg-slate-800 p-6 rounded-2xl shadow-sm border border-slate-100 dark:border-slate-700">
        <p class="text-xs font-bold text-slate-400 uppercase tracking-widest mb-1">Total Returns</p>
        <h3 class="text-2xl font-bold text-emerald-500">$<%= Number(stats.totalReturns).toLocaleString() %></h3>
    </div>
    <div class="bg-white dark:bg-slate-800 p-6 rounded-2xl shadow-sm border border-slate-100 dark:border-slate-700">
        <p class="text-xs font-bold text-slate-400 uppercase tracking-widest mb-1">Net Profit/Loss</p>
        <h3 class="text-2xl font-bold <%= stats.netProfit >= 0 ? 'text-emerald-500' : 'text-rose-500' %>">
            $<%= Number(stats.netProfit).toLocaleString() %>
        </h3>
    </div>
    <div class="bg-white dark:bg-slate-800 p-6 rounded-2xl shadow-sm border border-slate-100 dark:border-slate-700">
        <p class="text-xs font-bold text-slate-400 uppercase tracking-widest mb-1">Overall ROI</p>
        <h3 class="text-2xl font-bold <%= stats.overallROI >= 0 ? 'text-blue-500' : 'text-rose-500' %>">
            <%= stats.overallROI %>%
        </h3>
    </div>
</div>

<div class="grid grid-cols-1 xl:grid-cols-3 gap-8 mb-8">
    <div class="bg-white dark:bg-slate-800 p-6 rounded-2xl shadow-sm border border-slate-100 dark:border-slate-700 lg:col-span-1">
        <h3 class="text-sm font-bold text-slate-800 dark:text-slate-100 mb-6">Portfolio Balance</h3>
        <div class="h-64">
            <canvas id="roiDonutChart"></canvas>
        </div>
    </div>
    <div class="bg-white dark:bg-slate-800 p-6 rounded-2xl shadow-sm border border-slate-100 dark:border-slate-700 lg:col-span-2">
        <h3 class="text-sm font-bold text-slate-800 dark:text-slate-100 mb-6">Monthly ROI Trend (%)</h3>
        <div class="h-64">
            <canvas id="monthlyLineChart"></canvas>
        </div>
    </div>
</div>

<div class="bg-white dark:bg-slate-800 rounded-2xl shadow-sm border border-slate-100 dark:border-slate-700 mb-8 overflow-hidden">
    <div class="px-6 py-5 border-b border-slate-100 dark:border-slate-700">
        <h2 class="text-lg font-bold text-slate-800 dark:text-slate-100">Monthly ROI Report</h2>
    </div>
    <div class="overflow-x-auto">
        <table class="w-full text-left border-collapse">
            <thead>
                <tr class="bg-slate-50 dark:bg-slate-900/50">
                    <th class="px-6 py-4 text-xs font-bold text-slate-500 dark:text-slate-400 uppercase tracking-wider">Month</th>
                    <th class="px-6 py-4 text-xs font-bold text-slate-500 dark:text-slate-400 uppercase tracking-wider text-right">Investment</th>
                    <th class="px-6 py-4 text-xs font-bold text-slate-500 dark:text-slate-400 uppercase tracking-wider text-right">Returns</th>
                    <th class="px-6 py-4 text-xs font-bold text-slate-500 dark:text-slate-400 uppercase tracking-wider text-right">Profit</th>
                    <th class="px-6 py-4 text-xs font-bold text-slate-500 dark:text-slate-400 uppercase tracking-wider text-center">ROI</th>
                    <th class="px-6 py-4 text-xs font-bold text-slate-500 dark:text-slate-400 uppercase tracking-wider text-center">Action</th>
                </tr>
            </thead>
            <tbody class="divide-y divide-slate-100 dark:divide-slate-700">
                <% monthlyStats.reverse().forEach((ms, index) => { %>
                <tr class="hover:bg-slate-50 dark:hover:bg-slate-700/50 transition-colors">
                    <td class="px-6 py-4 font-bold text-slate-800 dark:text-slate-100"><%= moment(ms.month).format('MMMM YYYY') %></td>
                    <td class="px-6 py-4 font-medium text-rose-500 text-right">$<%= Number(ms.invest).toLocaleString() %></td>
                    <td class="px-6 py-4 font-medium text-emerald-500 text-right">$<%= Number(ms.returns).toLocaleString() %></td>
                    <td class="px-6 py-4 font-bold text-right <%= (ms.returns - ms.invest) >= 0 ? 'text-emerald-500' : 'text-rose-500' %>">
                        $<%= Number(ms.returns - ms.invest).toLocaleString() %>
                    </td>
                    <td class="px-6 py-4 text-center">
                        <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-bold <%= ms.roi >= 0 ? 'bg-emerald-100 text-emerald-700 dark:bg-emerald-900/30 dark:text-emerald-400' : 'bg-rose-100 text-rose-700 dark:bg-rose-900/30 dark:text-rose-400' %>">
                            <%= ms.roi %>%
                        </span>
                    </td>
                    <td class="px-6 py-4 text-center">
                        <button class="text-blue-600 hover:text-blue-700 font-bold text-sm bg-blue-50 dark:bg-blue-900/20 px-3 py-1.5 rounded-lg transition-all" onclick='showMonthDetail(<%- JSON.stringify(ms) %>)'>
                            Detail
                        </button>
                    </td>
                </tr>
                <% }) %>
            </tbody>
        </table>
    </div>
</div>

<div class="bg-white dark:bg-slate-800 rounded-2xl shadow-sm border border-slate-100 dark:border-slate-700 mb-8 overflow-hidden">
    <div class="px-6 py-5 border-b border-slate-100 dark:border-slate-700">
        <h2 class="text-lg font-bold text-slate-800 dark:text-slate-100">Detailed ROI Analysis per Account</h2>
    </div>
    <div class="overflow-x-auto">
        <table class="w-full text-left">
            <thead>
                <tr class="bg-slate-50 dark:bg-slate-900/50">
                    <th class="px-6 py-4 text-xs font-bold text-slate-500 dark:text-slate-400 uppercase tracking-wider">Prop Firm</th>
                    <th class="px-6 py-4 text-xs font-bold text-slate-500 dark:text-slate-400 uppercase tracking-wider">Type</th>
                    <th class="px-6 py-4 text-xs font-bold text-slate-500 dark:text-slate-400 uppercase tracking-wider">Balance</th>
                    <th class="px-6 py-4 text-xs font-bold text-slate-500 dark:text-slate-400 uppercase tracking-wider">Invest</th>
                    <th class="px-6 py-4 text-xs font-bold text-slate-500 dark:text-slate-400 uppercase tracking-wider">Returns</th>
                    <th class="px-6 py-4 text-xs font-bold text-slate-500 dark:text-slate-400 uppercase tracking-wider">ROI (%)</th>
                    <th class="px-6 py-4 text-xs font-bold text-slate-500 dark:text-slate-400 uppercase tracking-wider">Status</th>
                </tr>
            </thead>
            <tbody class="divide-y divide-slate-100 dark:divide-slate-700">
                <% accounts.forEach(acc => { %>
                <tr class="hover:bg-slate-50 dark:hover:bg-slate-700/50 transition-colors">
                    <td class="px-6 py-4">
                        <div class="font-bold text-slate-800 dark:text-slate-100"><%= acc.propfirm_name %></div>
                        <div class="text-[10px] text-slate-400 font-bold uppercase tracking-tighter">ID: #<%= acc.account_login_id || 'N/A' %></div>
                    </td>
                    <td class="px-6 py-4">
                        <span class="px-2 py-0.5 bg-slate-100 dark:bg-slate-700 rounded text-[10px] font-bold text-slate-600 dark:text-slate-300 uppercaseTracking-widest"><%= acc.account_type %></span>
                    </td>
                    <td class="px-6 py-4 font-semibold text-slate-700 dark:text-slate-300">$<%= Number(acc.balance).toLocaleString() %></td>
                    <td class="px-6 py-4 text-rose-500/80 font-medium">$<%= Number(acc.initial_cost || 0).toLocaleString() %></td>
                    <td class="px-6 py-4 text-emerald-500 font-bold">$<%= Number(acc.total_payout).toLocaleString() %></td>
                    <td class="px-6 py-4">
                        <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-bold <%= acc.roi >= 0 ? 'bg-emerald-100 text-emerald-700 dark:bg-emerald-900/30 dark:text-emerald-400' : 'bg-rose-100 text-rose-700 dark:bg-rose-900/30 dark:text-rose-400' %>">
                            <%= acc.roi ? Number(acc.roi).toFixed(2) : '0.00' %>%
                        </span>
                    </td>
                    <td class="px-6 py-4">
                        <span class="px-2 py-1 rounded text-[10px] font-bold uppercase tracking-wider <%= acc.status === 'active' ? 'bg-emerald-100 text-emerald-700 dark:bg-emerald-900/30 dark:text-emerald-400' : 'bg-rose-100 text-rose-700 dark:bg-rose-900/30 dark:text-rose-400' %>">
                            <%= acc.status %>
                        </span>
                    </td>
                </tr>
                <% }) %>
            </tbody>
        </table>
    </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
<script>
    function showMonthDetail(data) {
        let purchasesHtml = `<h4 class="text-slate-800 dark:text-slate-100 font-bold mb-3">Purchases</h4>
            <div class="overflow-x-auto mb-6"><table class="w-full text-left text-xs">
            <thead class="bg-slate-50 dark:bg-slate-900/50"><tr>
                <th class="px-4 py-2 text-slate-400 uppercase tracking-widest font-bold">Prop Firm</th>
                <th class="px-4 py-2 text-slate-400 uppercase tracking-widest font-bold">Size</th>
                <th class="px-4 py-2 text-slate-400 uppercase tracking-widest font-bold text-right">Price</th>
            </tr></thead><tbody class="divide-y divide-slate-100 dark:divide-slate-700">`;
        
        if (data.items.purchases.length === 0) {
            purchasesHtml += '<tr><td colspan="3" class="px-4 py-4 text-center text-slate-400">No purchases recorded.</td></tr>';
        } else {
            data.items.purchases.forEach(p => {
                purchasesHtml += `<tr>
                    <td class="px-4 py-3 font-bold text-slate-700 dark:text-slate-300">${p.propfirm_name}</td>
                    <td class="px-4 py-3 text-slate-500">$${Number(p.account_size).toLocaleString()}</td>
                    <td class="px-4 py-3 text-rose-500 font-bold text-right">$${Number(p.price).toLocaleString()}</td>
                </tr>`;
            });
        }
        purchasesHtml += '</tbody></table></div>';

        let payoutsHtml = `<h4 class="text-slate-800 dark:text-slate-100 font-bold mb-3">Approved Payouts</h4>
            <div class="overflow-x-auto"><table class="w-full text-left text-xs">
            <thead class="bg-slate-50 dark:bg-slate-900/50"><tr>
                <th class="px-4 py-2 text-slate-400 uppercase tracking-widest font-bold">Account</th>
                <th class="px-4 py-2 text-slate-400 uppercase tracking-widest font-bold text-right">Amount</th>
            </tr></thead><tbody class="divide-y divide-slate-100 dark:divide-slate-700">`;
        
        if (data.items.payouts.length === 0) {
            payoutsHtml += '<tr><td colspan="2" class="px-4 py-4 text-center text-slate-400">No payouts received.</td></tr>';
        } else {
            data.items.payouts.forEach(p => {
                payoutsHtml += `<tr>
                    <td class="px-4 py-3 font-bold text-slate-700 dark:text-slate-300"><strong>${p.propfirm_name}</strong>${p.account_login_id ? `<div class="text-[10px] text-slate-400 uppercase">ID: #${p.account_login_id}</div>` : ''}</td>
                    <td class="px-4 py-3 text-emerald-500 font-bold text-right">$${Number(p.amount).toLocaleString()}</td>
                </tr>`;
            });
        }
        payoutsHtml += '</tbody></table></div>';

        const netProfit = data.returns - data.invest;
        const colorClass = data.roi >= 0 ? 'text-emerald-500' : 'text-rose-500';

        const summaryHtml = `
            <div class="grid grid-cols-2 gap-4 mb-6">
                <div class="bg-slate-50 dark:bg-slate-900/80 p-4 rounded-xl border border-slate-100 dark:border-slate-700">
                    <p class="text-[10px] font-bold text-slate-400 uppercase tracking-widest mb-1">Monthly ROI</p>
                    <h3 class="text-xl font-bold ${colorClass}">${data.roi}%</h3>
                </div>
                <div class="bg-slate-50 dark:bg-slate-900/80 p-4 rounded-xl border border-slate-100 dark:border-slate-700">
                    <p class="text-[10px] font-bold text-slate-400 uppercase tracking-widest mb-1">Net Profit</p>
                    <h3 class="text-xl font-bold ${netProfit >= 0 ? 'text-emerald-500' : 'text-rose-500'}">$${Number(netProfit).toLocaleString()}</h3>
                </div>
            </div>
        `;

        const isDark = document.documentElement.classList.contains('dark');
        Swal.fire({
            title: `<div class="text-lg font-bold">Monthly Report: ${data.month}</div>`,
            html: `<div class="mt-4">${summaryHtml}${purchasesHtml}${payoutsHtml}</div>`,
            width: window.innerWidth < 768 ? '95%' : '650px',
            showConfirmButton: false,
            showCloseButton: true,
            background: isDark ? '#1e293b' : '#fff',
            color: isDark ? '#f8fafc' : '#1e293b',
            padding: '1.5rem',
            customClass: {
                popup: 'rounded-2xl border border-slate-200 dark:border-slate-700 shadow-2xl'
            }
        });
    }

    document.addEventListener('DOMContentLoaded', function() {
        const isDark = document.documentElement.classList.contains('dark');
        const secondaryColor = isDark ? '#94a3b8' : '#64748b';
        const gridColor = isDark ? 'rgba(255,255,255,0.05)' : 'rgba(0,0,0,0.05)';

        // Data for Donut Chart
        const donutCtx = document.getElementById('roiDonutChart').getContext('2d');
        const investVal = <%= stats.totalInvestment %>;
        const profitVal = <%= Math.max(0, stats.netProfit) %>;
        const totalVal = investVal + profitVal;
        
        const investPercent = totalVal > 0 ? ((investVal / totalVal) * 100).toFixed(1) : 0;
        const profitPercent = totalVal > 0 ? ((profitVal / totalVal) * 100).toFixed(1) : 0;

        new Chart(donutCtx, {
            type: 'doughnut',
            data: {
                labels: [`Investment (${investPercent}%)`, `Profit (${profitPercent}%)`],
                datasets: [{
                    data: [investVal, profitVal],
                    backgroundColor: ['#ef4444', '#10b981'],
                    borderWidth: 0
                }]
            },
            options: {
                responsive: true,
                maintainAspectRatio: false,
                plugins: {
                    tooltip: {
                        callbacks: {
                            label: function(context) {
                                const val = context.raw;
                                const pct = ((val / totalVal) * 100).toFixed(1);
                                return ` $${Number(val).toLocaleString()} (${pct}%)`;
                            }
                        }
                    },
                    legend: {
                        position: 'bottom',
                        labels: { 
                            color: secondaryColor,
                            usePointStyle: true,
                            font: { family: 'Poppins', size: 10, weight: '600' }
                        }
                    }
                },
                cutout: '75%'
            }
        });

        // Monthly ROI Line Chart
        const lineCtx = document.getElementById('monthlyLineChart').getContext('2d');
        const months = [<% monthlyStats.forEach(ms => { %>'<%= moment(ms.month).format('MMM YY') %>',<% }) %>];
        const monthROIs = [<% monthlyStats.forEach(ms => { %><%= ms.roi %>,<% }) %>];

        new Chart(lineCtx, {
            type: 'line',
            data: {
                labels: months,
                datasets: [{
                    label: 'ROI %',
                    data: monthROIs,
                    borderColor: '#2563eb',
                    backgroundColor: 'rgba(37, 99, 235, 0.1)',
                    fill: true,
                    tension: 0.4,
                    pointRadius: 6,
                    pointHoverRadius: 8,
                    pointBackgroundColor: '#2563eb',
                    pointBorderColor: '#fff',
                    pointBorderWidth: 2
                }]
            },
            options: {
                responsive: true,
                maintainAspectRatio: false,
                plugins: { legend: { display: false } },
                scales: {
                    y: { 
                        beginAtZero: true, 
                        ticks: { color: secondaryColor, callback: v => v + '%' },
                        grid: { color: gridColor }
                    },
                    x: { ticks: { color: secondaryColor }, grid: { display: false } }
                }
            }
        });
    });
</script>
